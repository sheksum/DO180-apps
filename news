# On pln-ipamaster — check current crypto policy
update-crypto-policies --show

# Set to DEFAULT:SHA1 to allow the older PKCS12 format custodia will send
update-crypto-policies --set DEFAULT:SHA1


# On cpeg
openssl pkcs12 -in /var/lib/ipa/ra-agent.pem -info -noout 2>&1 | head -5



# On pln-ipamaster
curl -sk https://ric-ipareplica.ipa.calix.local/ca/admin/ca/getStatus
nc -zv ric-ipareplica.ipa.calix.local 443
nc -zv ric-ipareplica.ipa.calix.local 8443


# On pln-ipamaster — do this NOW before starting
update-crypto-policies --set DEFAULT:SHA1
# Verify
update-crypto-policies --show

# Check connectivity to ALL CA replicas from pln-ipamaster
for host in cpeg-ipareplica.ipa.calix.local ric-ipareplica.ipa.calix.local; do
  echo "=== $host ==="
  nc -zv $host 443 2>&1
  nc -zv $host 8443 2>&1
done
