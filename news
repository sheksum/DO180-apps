# Already clean - so check the actual replication agreements
ldapsearch -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -Y EXTERNAL \
  -b "cn=config" \
  "(objectclass=nsds5replicationagreement)" \
  nsds5replicaLastUpdateStatus nsds5replicaHost 2>/dev/null | \
  grep -E "nsds5replica|dn:"
