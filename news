# Verify Dogtag is actually listening on 8443 on cpeg
ssh cpeg-ipareplica.ipa.calix.local "ss -tlnp | grep 8443"

# Check firewall on cpeg
ssh cpeg-ipareplica.ipa.calix.local "firewall-cmd --list-all"

# Check if it's a network ACL between Plano and Petaluma
# (Petaluma is 172.23.x.x, Plano is 10.172.x.x)
traceroute -T -p 8443 cpeg-ipareplica.ipa.calix.local

# On cpeg — open 8443 temporarily for the install
firewall-cmd --add-port=8443/tcp
# (no --permanent, just for the duration of the install)
