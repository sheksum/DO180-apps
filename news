# Full replication status
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "cn=meTocpeg-ipareplica.ipa.calix.local,cn=replica,cn=dc\3Dipa\2Cdc\3Dcalix\2Cdc\3Dlocal,cn=mapping tree,cn=config" \
  -s base "(objectclass=*)" 2>/dev/null > /tmp/pln-repl-agreement.txt

# Last 500 lines of install log
tail -500 /var/log/ipareplica-install.log > /tmp/pln-install-log.txt

# DS errors log
tail -1000 /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/errors > /tmp/pln-ds-errors.txt

# sysrestore state
cp /var/lib/ipa/sysrestore/sysrestore.state /tmp/pln-sysrestore.txt

# IPA version
ipa --version > /tmp/pln-ipa-version.txt


