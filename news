# Remove domain replication agreement
ldapdelete -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -Y EXTERNAL \
  "cn=meTopln-ipamaster.ipa.calix.local,cn=replica,cn=dc\3Dipa\2Cdc\3Dcalix\2Cdc\3Dlocal,cn=mapping tree,cn=config" 2>/dev/null

# Remove CA replication agreement
ldapdelete -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -Y EXTERNAL \
  "cn=caTopln-ipamaster.ipa.calix.local,cn=replica,cn=o\3Dipaca,cn=mapping tree,cn=config" 2>/dev/null
