# === 1. Pods using hostPath into kubelet dirs or node filesystem ===
kubectl get pods -A -o json | jq -r '
  .items[] as $p
  | $p.spec.volumes[]?
  | select(.hostPath != null)
  | "\($p.metadata.namespace)/\($p.metadata.name)\tpath=\(.hostPath.path)\tvol=\(.name)"
' | grep -viE '^(kube-system|longhorn|gpu-operator|cattle-|logging|cnpg-system|minio-operator)' | sort

# === 2. Pods with emptyDir volumes (potential model cache/scratch) ===
kubectl get pods -A -o json | jq -r '
  .items[] as $p
  | $p.spec.volumes[]?
  | select(.emptyDir != null)
  | "\($p.metadata.namespace)/\($p.metadata.name)\tvol=\(.name)\tsizeLimit=\(.emptyDir.sizeLimit // "UNCAPPED")\tmedium=\(.emptyDir.medium // "disk")"
' | grep -viE '^(kube-system|cattle-|longhorn|logging)' | sort | head -40

# === 3. Focus: inference namespaces — how are they handling model weights? ===
for ns in codestral-inference deephat-v2-hf-inference devstral-small-2-inference \
          gemma4-31b-inference glm-flash-inference llama-4-maverick-inference \
          nemotron-inference text-embeddings embeddings speaches; do
  echo "=== $ns ==="
  kubectl -n $ns get pods -o json 2>/dev/null | jq -r '
    .items[] as $p
    | $p.spec.volumes[]?
    | "\($p.metadata.name)\tvol=\(.name)\ttype=\(
        if .hostPath then "hostPath:\(.hostPath.path)"
        elif .emptyDir then "emptyDir:\(.emptyDir.sizeLimit // "uncapped")"
        elif .persistentVolumeClaim then "pvc:\(.persistentVolumeClaim.claimName)"
        elif .configMap then "configMap"
        elif .secret then "secret"
        elif .projected then "projected"
        else "other"
      end)"'
done

# === 4. DIRECTLY check disk usage on nodes — the smoking gun ===
# On each node, check what's eating /var/lib/kubelet and the root disk
for n in aamslc4kbw01 aamslc4kbw02 aamslc4kbw03 aamslc4kbw04 aamslc4kbw05 aamslc4kbg01; do
  echo "=== $n ==="
  ssh $n 'df -h / /var/lib 2>/dev/null | tail -3; echo "---"; sudo du -sh /var/lib/kubelet/pods/*/volumes/kubernetes.io~empty-dir/* 2>/dev/null | sort -rh | head -10'
done

# === 5. The GPU node specifically — biggest risk (models are huge) ===
ssh aamslc4kbg01 'df -h; echo "---"; sudo du -sh /var/lib/kubelet/pods/*/volumes/* 2>/dev/null | sort -rh | head -20; echo "---"; sudo du -sh /var/lib/containerd 2>/dev/null'

# === 6. Cross-reference: PVCs mounted by inference pods (the "right way" group) ===
for ns in codestral-inference deephat-v2-hf-inference devstral-small-2-inference \
          gemma4-31b-inference llama-4-maverick-inference text-embeddings; do
  echo "=== $ns ==="
  kubectl -n $ns get pvc 2>/dev/null
done

# === 7. Longhorn volume sizes for inference namespaces ===
kubectl get pv -o json | jq -r '
  .items[]
  | select(.spec.claimRef.namespace | test("inference|embeddings|speaches"))
  | "\(.spec.claimRef.namespace)/\(.spec.claimRef.name)\tsize=\(.spec.capacity.storage)\tclass=\(.spec.storageClassName)"
'

# === 8. Node filesystem growth over time (any ephemeral-storage eviction history?) ===
kubectl get events -A --field-selector reason=Evicted 2>/dev/null | head
kubectl describe nodes | grep -A2 'ephemeral-storage' | head -40

# === 9. EphemeralStorage requests/limits — are they even set? ===
kubectl get pods -A -o json | jq -r '
  .items[]
  | select(.metadata.namespace | test("inference|embedding|speaches|aitk"))
  | .spec.containers[]
  | "\(.name)\tephemeral-storage.req=\(.resources.requests."ephemeral-storage" // "NONE")\tephemeral-storage.lim=\(.resources.limits."ephemeral-storage" // "NONE")"
' | sort -u | head
