# 1. Total count of Longhorn volumes and their state
kubectl get volumes.longhorn.io -A --no-headers 2>/dev/null | wc -l
kubectl get volumes.longhorn.io -A -o json 2>/dev/null | jq -r '.items[] | .status.state' | sort | uniq -c
kubectl get volumes.longhorn.io -A -o json 2>/dev/null | jq -r '.items[] | .status.robustness' | sort | uniq -c

# 2. Total count of PVCs using Longhorn storage class
kubectl get pvc -A -o json | jq -r '.items[] | select(.spec.storageClassName=="longhorn") | "\(.metadata.namespace)/\(.metadata.name)"' | wc -l
kubectl get pvc -A -o json | jq -r '.items[] | select(.spec.storageClassName=="longhorn") | "\(.metadata.namespace)"' | sort | uniq -c | sort -rn

# 3. PVCs NOT on longhorn (and what class are they using?)
kubectl get pvc -A -o json | jq -r '.items[] | select(.spec.storageClassName!="longhorn") | "\(.metadata.namespace)/\(.metadata.name)\tclass=\(.spec.storageClassName // "NONE")"'

# 4. All storage classes in the cluster — what's available beyond Longhorn?
kubectl get storageclass
kubectl get storageclass -o json | jq -r '.items[] | "\(.metadata.name)\tprovisioner=\(.provisioner)\tdefault=\(.metadata.annotations["storageclass.kubernetes.io/is-default-class"] // "false")"'

# 5. Pods using hostPath (NOT Longhorn) — what workloads bypass storage entirely?
kubectl get pods -A -o json | jq -r '
  .items[] as $p
  | $p.spec.volumes[]?
  | select(.hostPath != null)
  | "\($p.metadata.namespace)/\($p.metadata.name)\tpath=\(.hostPath.path)"
' | grep -viE '^(kube-system|longhorn|gpu-operator|cattle-|logging|cnpg-system|minio-operator|rabbitmq-system|redis-operator)' | sort -u

# 6. Pods using uncapped emptyDir (in-memory or disk scratch)
kubectl get pods -A -o json | jq -r '
  .items[] as $p
  | $p.spec.volumes[]?
  | select(.emptyDir != null and .emptyDir.sizeLimit == null)
  | "\($p.metadata.namespace)/\($p.metadata.name)\tvol=\(.name)"
' | grep -viE '^(kube-system|cattle-|longhorn|logging)' | awk -F/ '{print $1}' | sort | uniq -c | sort -rn

# 7. Longhorn settings — the key policy settings
kubectl -n longhorn-system get setting -o json 2>/dev/null | jq -r '.items[] | select(.metadata.name | test("replica|backup|node|anti-affinity|data-locality|snapshot")) | "\(.metadata.name) = \(.value)"'
# Also try the "longhorn" namespace in case that's the active one
kubectl -n longhorn get setting -o json 2>/dev/null | jq -r '.items[] | select(.metadata.name | test("replica|backup|node|anti-affinity|data-locality|snapshot")) | "\(.metadata.name) = \(.value)"'

# 8. Which namespace is actually hosting the live Longhorn installation?
kubectl -n longhorn get pods -o name 2>/dev/null | wc -l
kubectl -n longhorn-system get pods -o name 2>/dev/null | wc -l
kubectl get crd | grep longhorn.io
# and where does the CRD point?
kubectl get volumes.longhorn.io -A -o json | jq -r '.items[0] | .metadata.namespace' 2>/dev/null

# 9. Longhorn backup target — is anything wired up?
kubectl get backuptarget.longhorn.io -A 2>/dev/null
kubectl get recurringjob.longhorn.io -A 2>/dev/null

# 10. Summary: what % of PVCs are Longhorn, what % are other
kubectl get pvc -A -o json | jq -r '.items[].spec.storageClassName' | sort | uniq -c | sort -rn
