# Current state of all certs
kubectl get certificate -A

# For each failing cert, the actual error reason
kubectl get certificate -A -o json | jq -r '
  .items[]
  | select(.status.conditions[]? | select(.type=="Ready") | .status == "False")
  | "\(.metadata.namespace)/\(.metadata.name)\treason=\(.status.conditions[] | select(.type=="Ready") | .reason)\tmessage=\(.status.conditions[] | select(.type=="Ready") | .message)"
'

# Any ClusterIssuer or Issuer configured at all?
kubectl get clusterissuer
kubectl get issuer -A

# Cert-manager pods healthy?
kubectl -n cert-manager get pods

# Recent cert-manager logs - look for the actual failure
kubectl -n cert-manager logs -l app=cert-manager --tail=50 2>/dev/null | grep -iE 'error|fail' | tail -20

# What's actually serving TLS right now? (wildcard cert details)
kubectl get secret -A -o json | jq -r '
  .items[]
  | select(.type=="kubernetes.io/tls" and (.metadata.name | test("wildcard")))
  | "\(.metadata.namespace)/\(.metadata.name)"
'

# Check the wildcard cert's actual expiry - pick one
kubectl -n cattle-system get secret tls-rancher -o jsonpath='{.data.tls\.crt}' | base64 -d | openssl x509 -noout -dates -subject -issuer 2>/dev/null
