export KUBECONFIG=/etc/rancher/rke2/rke2.yaml

# --- Control plane / etcd health ---
# Best practice: 3 healthy etcd members, one leader, DB size < 2GB, low raft index skew
sudo /var/lib/rancher/rke2/bin/kubectl -n kube-system exec -it etcd-$(hostname -s).ttmtech.local -- sh -c '
ETCDCTL_API=3 etcdctl \
  --endpoints=https://127.0.0.1:2379 \
  --cacert=/var/lib/rancher/rke2/server/tls/etcd/server-ca.crt \
  --cert=/var/lib/rancher/rke2/server/tls/etcd/server-client.crt \
  --key=/var/lib/rancher/rke2/server/tls/etcd/server-client.key \
  endpoint status --cluster -w table'

# Alarms? Compact/defrag history?
sudo /var/lib/rancher/rke2/bin/kubectl -n kube-system exec -it etcd-$(hostname -s).ttmtech.local -- sh -c '
ETCDCTL_API=3 etcdctl \
  --endpoints=https://127.0.0.1:2379 \
  --cacert=/var/lib/rancher/rke2/server/tls/etcd/server-ca.crt \
  --cert=/var/lib/rancher/rke2/server/tls/etcd/server-client.crt \
  --key=/var/lib/rancher/rke2/server/tls/etcd/server-client.key \
  alarm list'

# --- Fixed registration / VIP ---
# Best practice: stable endpoint in front of servers; servers should not reference each other by IP
getent hosts api.kbai.ttmtech.local
dig +short api.kbai.ttmtech.local
# Is there a VIP in the cluster? (kube-vip / MetalLB / external LB)
kubectl get pods -A | grep -Ei 'kube-vip|metallb|keepalived|haproxy'
# Check static pods on servers
sudo ls -la /var/lib/rancher/rke2/agent/pod-manifests/ 2>/dev/null
# Check for an external LB reference in workers' config
ssh aamslc4kbw01 'cat /etc/rancher/rke2/config.yaml' 2>/dev/null | grep -E 'server:|token:'

# --- Physical placement / anti-affinity ---
# Best practice: servers on different ESXi hosts / racks
kubectl get nodes -o json | jq -r '.items[] | "\(.metadata.name)\tproviderID=\(.spec.providerID // "NONE")"'
# On vSphere side — anti-affinity rule for masters?  (command for you/infra team, not kubectl)

# --- Version drift ---
# Best practice: all nodes on the same minor; within one patch during rolling upgrade
kubectl get nodes -o json | jq -r '.items[] | "\(.metadata.name)\t\(.status.nodeInfo.kubeletVersion)"' | sort -k2

# --- Workload HA sweep (user namespaces only) ---
# Best practice: replicas>=2 for stateless prod workloads, PDBs in place, readiness probes, anti-affinity
USER_NS=$(kubectl get ns -o name | cut -d/ -f2 | grep -Ev '^(kube-|cattle-|longhorn|rancher|default$|cnpg-system|minio-operator|redis-operator|rabbitmq-system|cert-manager|external-secrets|gpu-operator|keda|istio-system|dex|ssoready|prisma-migrations|logging)$')

echo "=== Single-replica deployments in prod ns ==="
for ns in $USER_NS; do
  kubectl -n $ns get deploy -o json 2>/dev/null | jq -r --arg ns $ns '.items[] | select(.spec.replicas==1) | "\($ns)/\(.metadata.name)\treplicas=\(.spec.replicas)"'
done

echo "=== Namespaces with ZERO PodDisruptionBudgets ==="
for ns in $USER_NS; do
  count=$(kubectl -n $ns get pdb --no-headers 2>/dev/null | wc -l)
  [ "$count" -eq 0 ] && echo "$ns: NO PDBs"
done

echo "=== Pods missing readiness probes ==="
kubectl get pods -A -o json | jq -r '
  .items[]
  | select(.metadata.namespace | test("^(kube-system|cattle-|longhorn|rancher)") | not)
  | select(.spec.containers[] | .readinessProbe == null)
  | "\(.metadata.namespace)/\(.metadata.name)"' | sort -u | head -40

echo "=== Pods missing resource requests/limits ==="
kubectl get pods -A -o json | jq -r '
  .items[]
  | select(.metadata.namespace | test("^(kube-system|cattle-|longhorn)") | not)
  | select(.spec.containers[] | .resources.requests == null or .resources.limits == null)
  | "\(.metadata.namespace)/\(.metadata.name)"' | sort -u | head -40

echo "=== Deployments with NO pod anti-affinity or topology spread ==="
for ns in $USER_NS; do
  kubectl -n $ns get deploy -o json 2>/dev/null | jq -r --arg ns $ns '
    .items[]
    | select((.spec.replicas // 0) > 1)
    | select(.spec.template.spec.affinity.podAntiAffinity == null and .spec.template.spec.topologySpreadConstraints == null)
    | "\($ns)/\(.metadata.name)\tMULTI_REPLICA_NO_SPREAD"'
done

echo "=== GPU-pinned workloads (need node failure plan) ==="
kubectl get pods -A -o json | jq -r '
  .items[]
  | select(.spec.containers[].resources.limits."nvidia.com/gpu" != null or .spec.containers[].resources.limits."nvidia.com/mig-3g.71gb" != null or .spec.containers[].resources.limits."nvidia.com/mig-4g.71gb" != null)
  | "\(.metadata.namespace)/\(.metadata.name)\tnode=\(.spec.nodeName)"'

# --- CoreDNS HA ---
# Longhorn best practice: CoreDNS with >=2 replicas
kubectl -n kube-system get deploy rke2-coredns-rke2-coredns -o jsonpath='{.spec.replicas}{"\n"}'

# --- Ingress controller distribution ---
# 5 ingress pods observed — on which nodes?
kubectl -n kube-system get pods -l app.kubernetes.io/name=rke2-ingress-nginx -o wide
