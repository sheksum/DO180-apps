# What task-worker-ts does — environment and args
kubectl -n task-worker-ts get deploy task-worker-ts -o yaml | sed -n '/env:/,/name:\|volumeMounts:/p' | head -40

# What audit-log-exporter ships to
kubectl -n audit-log-exporter get deploy audit-log-exporter -o yaml | sed -n '/env:/,/name:\|volumeMounts:/p' | head -40

# What mcp-unified exposes
kubectl -n mcp get deploy mcp-unified -o yaml | sed -n '/env:/,/name:\|volumeMounts:/p' | head -60

# What external-poller and external-sync actually do
kubectl -n external-sync get deploy external-sync-files -o yaml | sed -n '/env:/,/name:\|volumeMounts:/p' | head -40
kubectl -n external-poller get cronjob -o yaml 2>/dev/null | grep -E 'schedule:|image:|args:' | head

# What LiteLLM is configured to route to
kubectl -n litellm get configmap litellm-config -o yaml 2>/dev/null | grep -E 'model_name:|model:|api_base:' | head -40
