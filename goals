#!/usr/bin/env bash

# Fail fast (useful if docker isn't installed or a command fails)
set -euo pipefail

# Ensure the HAProxy configuration file has the correct permissions
chmod 744 haproxy.cfg

# Build the HAProxy Docker image with the specified tag
docker build -t haproxy-ttm:latest .

# Stop and remove any existing 'haproxy' container to avoid conflicts
docker stop haproxy || true
docker rm haproxy || true

# Run the HAProxy container in detached mode with appropriate port mappings and restart policy
# Kubernetes API server
# RKE2 supervisor port
# HTTP traffic
# HTTPS traffic
# HAProxy stats interface
docker run --log-opt max-size=10m --name haproxy -d \
  -p 6443:6443 \
  -p 9345:9345 \
  -p 80:80 \
  -p 443:443 \
  -p 8404:8404 \
  --restart=unless-stopped \
  haproxy-ttm:latest

echo
echo "=============================================================="
echo "HAProxy is starting in the background."
echo
echo "You can check the status of the container:"
echo "  docker ps -a | grep haproxy"
echo "To follow logs:"
echo "  docker logs -f haproxy"
echo
echo "Once HAProxy is running, open a browser on your network and navigate to:"
echo "  http://<this-host-ip>:8404/stats"
echo "Replace <this-host-ip> with your load balancer's IP address or hostname."
echo "You should see the HAProxy statistics page."
echo
echo "NOTE: None of the backend nodes (masters/workers) will appear as healthy until RKE2 is set up on those nodes."
echo "=============================================================="
