# From any workstation with kubeconfig
kubectl version
kubectl cluster-info
kubectl get nodes -o wide --show-labels
kubectl get ns

# From a control-plane (server) node — RKE2 specifics
sudo systemctl status rke2-server
rke2 --version
cat /etc/rancher/rke2/config.yaml               # the install-time config — critical artifact
sudo ls /var/lib/rancher/rke2/server/manifests/ # auto-deployed HelmCharts/manifests
sudo ls /var/lib/rancher/rke2/agent/            # on workers: /etc/rancher + agent dir

# Is this cluster managed by Rancher, or standalone RKE2?
kubectl get ns cattle-system 2>/dev/null && echo "Rancher-managed"
kubectl -n cattle-system get pods
kubectl get clusters.management.cattle.io -A 2>/dev/null   # Rancher CRD
kubectl get clusters.provisioning.cattle.io -A 2>/dev/null

# RKE2 bundled components — know what's baked in vs added
kubectl get pods -n kube-system
# Expect: etcd-*, kube-apiserver-*, kube-controller-manager-*, kube-scheduler-*,
#         rke2-canal-* (or cilium), rke2-coredns-*, rke2-ingress-nginx-*,
#         rke2-metrics-server-*, rke2-snapshot-controller-*, helm-install-*


# Server (control-plane) count — need 3 or 5, not 1 or 2
kubectl get nodes -l node-role.kubernetes.io/control-plane=true -o wide
kubectl get nodes -o json | jq -r '.items[] | "\(.metadata.name)\t\(.status.nodeInfo.kubeletVersion)\t\(.metadata.labels["topology.kubernetes.io/zone"] // "NO_ZONE")\t\(.metadata.labels["node-role.kubernetes.io/control-plane"] // "worker")"'

# Fixed registration address — is there one? If not, losing server[0] breaks joins
grep -E 'server|tls-san' /etc/rancher/rke2/config.yaml

# etcd — RKE2 runs etcd as a static pod
kubectl -n kube-system get pods -l component=etcd -o wide
# Direct etcdctl from a server node
sudo /var/lib/rancher/rke2/bin/kubectl -n kube-system exec -it etcd-$(hostname) -- sh -c '
  ETCDCTL_API=3 etcdctl \
    --endpoints=https://127.0.0.1:2379 \
    --cacert=/var/lib/rancher/rke2/server/tls/etcd/server-ca.crt \
    --cert=/var/lib/rancher/rke2/server/
