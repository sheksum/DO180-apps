# === "Is the cluster under memory pressure?" ===
kubectl top nodes
kubectl describe nodes | grep -A5 'Conditions' | grep -E 'Pressure|Ready' | head -20

# === "What's actually broken right now?" ===
kubectl get pods -A | grep -vE 'Running|Completed' | head -20
kubectl get events -A --sort-by='.lastTimestamp' | grep -iE 'warning|error|failed' | tail -20

# === "How old are our etcd backups?" ===
sudo ls -lht /var/lib/rancher/rke2/server/db/snapshots/ | head -5

# === "Who logged in recently?" (audit log)
sudo grep -h '"verb":"create"' /var/log/kubernetes/audit/audit.log 2>/dev/null | \
  jq -r '.user.username' 2>/dev/null | sort | uniq -c | sort -rn | head

# === "What's the biggest consumer of cluster resources?" ===
kubectl top pods -A --sort-by=memory | head -15
kubectl top pods -A --sort-by=cpu | head -15

# === Degraded Longhorn volume — what's the impact? ===
kubectl -n longhorn-system get volume.longhorn.io -o json | \
  jq -r '.items[] | select(.status.robustness == "degraded") | 
    "\(.metadata.name) used by \(.status.kubernetesStatus.namespace)/\(.status.kubernetesStatus.workloadsStatus[0].workloadName // "unknown")"'

# === Are we tracking any real security events? ===
sudo tail -1000 /var/log/kubernetes/audit/audit.log 2>/dev/null | \
  jq -r 'select(.verb=="create" and .objectRef.resource=="pods" and .responseStatus.code==201) | 
    "\(.requestReceivedTimestamp)\t\(.user.username)\t\(.objectRef.namespace)"' 2>/dev/null | tail -10

