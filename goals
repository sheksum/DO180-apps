# Is the fleet-agent actually running and healthy?
kubectl -n cattle-fleet-system get pods
# Any GitRepos defined anywhere?
kubectl get gitrepos.fleet.cattle.io -A
# Any Bundles (compiled from GitRepos)?
kubectl get bundles.fleet.cattle.io -A
# Any Flux CRDs present?
kubectl get crd | grep -iE 'flux|argo'
