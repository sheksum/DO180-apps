kubectl get cluster.postgresql.cnpg.io -A -o json | jq -r '.items[] | "\(.metadata.namespace)/\(.metadata.name)\tinstances=\(.spec.instances)\tbackup=\(.spec.backup.barmanObjectStore.destinationPath // "NONE")"'
kubectl get scheduledbackup.postgresql.cnpg.io -A

