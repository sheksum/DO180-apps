# ==== Investigate the VIP / DNS / LB situation ====
getent hosts api.kbai.ttmtech.local
dig api.kbai.ttmtech.local +short
dig api.kbai.ttmtech.local +noall +answer

# What do WORKERS think the server URL is?
for n in aamslc4kbw01 aamslc4kbw02 aamslc4kbw03 aamslc4kbw04 aamslc4kbw05 aamslc4kbg01; do
  echo "=== $n ==="
  ssh $n "grep -E '^server' /etc/rancher/rke2/config.yaml 2>/dev/null; cat /etc/rancher/rke2/config.yaml.d/*.yaml 2>/dev/null | grep -E '^server'"
done

# What does DNS resolve master-0/1/2 to? (tls-san entries)
for h in master-0 master-1 master-2 api; do
  echo "$h.kbai.ttmtech.local -> $(getent hosts $h.kbai.ttmtech.local | awk '{print $1}')"
done

# ==== CIS profile verification ====
grep -i '^profile:' /etc/rancher/rke2/config.yaml
# Confirm etcd runs as root (NOT etcd user) — this is a CIS miss
sudo /var/lib/rancher/rke2/bin/crictl inspect $(sudo /var/lib/rancher/rke2/bin/crictl ps --name etcd -q | head -1) | grep -iE 'runAsUser|runAsGroup|uid|gid' | head
id etcd 2>/dev/null || echo "no etcd host user — CIS fail"

# ==== Pod Security Admission — cluster-wide default ====
grep -i admission /etc/rancher/rke2/config.yaml
sudo ls /etc/rancher/rke2/
sudo cat /etc/rancher/rke2/rke2-pss.yaml 2>/dev/null
kubectl get ns -o json | jq -r '.items[] | "\(.metadata.name)\tenforce=\(.metadata.labels["pod-security.kubernetes.io/enforce"] // "NONE")"' | column -t

# ==== Secrets encryption at rest ====
sudo /var/lib/rancher/rke2/bin/rke2 secrets-encrypt status 2>/dev/null

# ==== Audit log — is anything actually being written? ====
sudo cat /etc/kubernetes/audit/policy.yaml 2>/dev/null
sudo ls -lh /var/log/kubernetes/audit/ 2>/dev/null
sudo tail -5 /var/log/kubernetes/audit/audit.log 2>/dev/null | head

# ==== RBAC — cluster-admins ====
kubectl get clusterrolebinding -o json | jq -r '
  .items[] | select(.roleRef.name=="cluster-admin") 
  | "\(.metadata.name)\t\(.subjects // [] | map("\(.kind):\(.namespace // "-")/\(.name)") | join(" , "))"' | column -t -s $'\t'

# ==== NetworkPolicy coverage ====
echo "Namespaces with ZERO NetworkPolicies:"
for ns in $(kubectl get ns -o name | cut -d/ -f2); do
  count=$(kubectl -n $ns get netpol --no-headers 2>/dev/null | wc -l)
  [ "$count" -eq 0 ] && echo "  $ns"
done
echo
echo "All NetworkPolicies:"
kubectl get netpol -A

# ==== Privileged / host-access pods ====
kubectl get pods -A -o json | jq -r '
  .items[] | select(
    (.spec.containers[]?.securityContext.privileged==true) or
    (.spec.hostNetwork==true) or
    (.spec.hostPID==true) or
    (.spec.volumes[]?.hostPath != null)
  ) | "\(.metadata.namespace)/\(.metadata.name)\tpriv=\([.spec.containers[]?.securityContext.privileged] | any)\thostNet=\(.spec.hostNetwork // false)\thostPID=\(.spec.hostPID // false)"' | sort -u

# ==== Longhorn: which namespace is real, replica config, backup target ====
kubectl -n longhorn get pods 2>/dev/null | head -5
kubectl -n longhorn-system get pods 2>/dev/null | head -5
kubectl get volumes.longhorn.io -A 2>/dev/null | awk '{print $1}' | sort -u
kubectl -n longhorn-system get setting default-replica-count backup-target backup-target-credential-secret replica-soft-anti-affinity -o custom-columns=NAME:.metadata.name,VALUE:.value 2>/dev/null

# Volumes at risk (degraded or <2 replicas)
kubectl get volumes.longhorn.io -A -o json 2>/dev/null | jq -r '
  .items[] 
  | "\(.metadata.name)\treplicas=\(.spec.numberOfReplicas)\tstate=\(.status.state)\trobustness=\(.status.robustness)\tsize=\(.spec.size)"' | head -30

# ==== CNPG (Postgres) backup config ====
