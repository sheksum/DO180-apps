# Temporarily change logLevel to debug (ArgoCD will revert in ~3-5 min, 
# so we need to read logs quickly after speakers restart)
oc patch metallb metallb -n metallb-system --type merge -p '{"spec":{"logLevel":"debug"}}'

# Wait for the operator to roll out new speaker pods
sleep 30 && oc get pods -n metallb-system -l component=speaker -w


# Grab the full logs immediately — this will show us EVERYTHING:
# interface matching, VIP binding attempts, ARP announcements, election results
oc logs -n metallb-system -l component=speaker -c speaker --tail=500

# And quickly check if VIPs are bound now
ssh -i ~/.ssh/ocp-ai core@10.172.248.150 "ip addr show | grep '10.172.194.16'"


# Pause ArgoCD auto-sync on the metallb app
oc patch application metallb -n openshift-gitops --type merge -p '{"spec":{"syncPolicy":null}}'

# Then patch the logLevel (won't be reverted until you re-enable sync)
oc patch metallb metallb -n metallb-system --type merge -p '{"spec":{"logLevel":"debug"}}'


oc patch application metallb -n openshift-gitops --type merge -p '{"spec":{"syncPolicy":{"automated":{"selfHeal":true,"prune":true}}}}'
