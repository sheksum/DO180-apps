# 1. Fix ServiceL2Status
oc delete servicel2status --all -n metallb-system
oc delete pod -n metallb-system -l component=speaker
sleep 20

# 2. Verify speakers are back with proper service refs
oc get servicel2status -n metallb-system -o custom-columns='NAME:.metadata.name,NODE:.status.node,SVC:.spec.serviceRef.name,NS:.spec.serviceRef.namespace'

# 3. Add MASQUERADE on ALL masters (VIP can be on any master)
for node in ocp-ai-master01.calix.local ocp-ai-master02.calix.local ocp-ai-master03.calix.local; do
  echo "=== $node ==="
  oc debug node/$node -- nsenter -t 1 -m -u -i -n -p -- bash -c '
    iptables -t nat -C POSTROUTING -s 10.172.194.0/24 -d 172.30.0.0/16 -o br-ex -j MASQUERADE 2>/dev/null || \
      iptables -t nat -A POSTROUTING -s 10.172.194.0/24 -d 172.30.0.0/16 -o br-ex -j MASQUERADE
    iptables -t nat -C POSTROUTING -s 10.172.198.0/24 -d 172.30.0.0/16 -o br-ex -j MASQUERADE 2>/dev/null || \
      iptables -t nat -A POSTROUTING -s 10.172.198.0/24 -d 172.30.0.0/16 -o br-ex -j MASQUERADE
    iptables -t nat -C POSTROUTING -s 10.172.202.0/24 -d 172.30.0.0/16 -o br-ex -j MASQUERADE 2>/dev/null || \
      iptables -t nat -A POSTROUTING -s 10.172.202.0/24 -d 172.30.0.0/16 -o br-ex -j MASQUERADE
    echo "MASQUERADE rules added"
    iptables -t nat -S POSTROUTING | grep MASQ
  '
done

# 4. Test
oc debug node/ocp-ai-master02.calix.local -- chroot /host nc -zv -w 5 10.172.194.160 9000
