oc get packagemanifest metallb-operator -n openshift-marketplace -o jsonpath='{.status.channels[?(@.name=="stable")].entries[*].name}' | tr ' ' '\n' | grep metallb


oc get packagemanifest metallb-operator -n openshift-marketplace -o jsonpath='{.status.channels[?(@.name=="stable")].currentCSV}'


oc delete subscription metallb-operator -n metallb-system
oc delete csv metallb-operator.v4.20.0-202603152019 -n metallb-system


oc delete installplan install-29ckt install-rccbn install-vv6sc -n metallb-system


cat <<'EOF' | oc apply -f -
