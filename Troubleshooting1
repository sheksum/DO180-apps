# Fix the ARP entry on master02 to use the CORRECT MAC
oc debug node/ocp-ai-master02.calix.local -- nsenter -t 1 -m -u -i -n -p -- bash -c '
  ip neigh del 10.172.194.160 dev bnd0.1794 2>/dev/null
  ip neigh replace 10.172.194.160 lladdr 00:25:b5:50:0a:65 dev bnd0.1794
  echo "=== ARP entry ==="
  ip neigh show 10.172.194.160
'

# Now test — this should finally work
oc debug node/ocp-ai-master02.calix.local -- chroot /host nc -zv -w 3 10.172.194.160 9000
