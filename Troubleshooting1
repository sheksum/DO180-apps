# Delete all stale ServiceL2Status objects
oc delete servicel2status --all -n metallb-system


# Then restart the speakers to force a clean reconciliation
oc delete pods -n metallb-system -l component=speaker


# Verify new ServiceL2Status objects are created
oc get servicel2status -A -o wide


# Check if VIPs are now bound
for node in master01 master02 master03; do
  echo "=== $node ==="
  ssh -i .ssh/ocp-ai core@ocp-ai-${node}.calix.local "ip addr show | grep -E '10.172.194.1(6[0-9]|7[0-9])|10.172.248.175'"
done

# Ping test
ping -c 3 10.172.194.160
