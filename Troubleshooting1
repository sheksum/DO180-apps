# 1. Re-add the VIP (MetalLB L2 only does ARP, doesn't assign the IP)
ip addr add 10.172.194.160/32 dev bnd0.1794

# 2. Disable reverse path filtering (packets arrive on bnd0.1794 but route reply via br-ex)
echo 0 > /proc/sys/net/ipv4/conf/bnd0.1794/rp_filter
echo 0 > /proc/sys/net/ipv4/conf/all/rp_filter

# 3. Add the MASQUERADE rule
iptables -t nat -I POSTROUTING -m conntrack --ctstate DNAT -o br-ex -j MASQUERADE


nsenter -t 1 -m -u -i -n -p -- nc -w 5 -zv 10.172.194.160 9000
