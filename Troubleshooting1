echo "=== MetalLB service allocation ==="
for ns in pai-dev pai-prod pai-test; do
  echo "--- $ns ---"
  oc get svc -n $ns --field-selector spec.type=LoadBalancer -o custom-columns='NAME:.metadata.name,EXTERNAL-IP:.status.loadBalancer.ingress[0].ip,ENDPOINTS:.subsets'
done

echo ""
echo "=== Speaker logs - broader search ==="
pod=$(oc get pods -n metallb-system -l component=speaker --field-selector spec.nodeName=ocp-ai-master01.calix.local -o name)
oc logs $pod -n metallb-system --tail=500 | grep -v "interface to exclude" | tail -20
