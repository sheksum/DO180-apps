for node in ocp-ai-master01.calix.local ocp-ai-master02.calix.local ocp-ai-master03.calix.local; do
  echo "=== $node ==="
  oc debug node/$node -- chroot /host bash -c '
    for iface in bnd0.1794 bnd0.1797 bnd0.1798; do
      current=$(cat /proc/sys/net/ipv4/conf/$iface/rp_filter 2>/dev/null)
      echo "$iface rp_filter=$current"
      echo 0 > /proc/sys/net/ipv4/conf/$iface/rp_filter
      echo "  -> set to 0"
    done
    echo 0 > /proc/sys/net/ipv4/conf/all/rp_filter
    echo "all rp_filter -> 0"
  '
done

for vip in "10.172.194.160:9000" "10.172.194.161:19530" "10.172.194.163:5432" "10.172.202.160:9000" "10.172.202.161:19530" "10.172.198.160:9000" "10.172.198.161:19530"; do
  ip=${vip%:*}
  port=${vip#*:}
  echo -n "$vip -> "
  nc -w5 -zv $ip $port 2>&1 | tail -1
done
