# 1. Does the ServiceL2Status CRD exist?
oc get crd | grep metallb

# 2. Are there any ServiceL2Status resources?
oc get servicel2statuses -n metallb-system

# 3. What MetalLB version is running?
oc get csv -n metallb-system

# 4. Broader speaker logs — see what's actually happening (not filtered)
oc logs -n metallb-system speaker-96xwt -c speaker --tail=100

# 5. Check if there were recent operator upgrades that might have 
#    left CRDs in a bad state
oc get installplan -n metallb-system --sort-by=.metadata.creationTimestamp
