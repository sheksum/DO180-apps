# Step 1: Delete ALL stale ServiceL2Status objects
oc delete servicel2status --all -n metallb-system


# Step 2: Restart speaker pods so they reconcile fresh
oc delete pods -n metallb-system -l component=speaker


# Step 3: Wait ~30 seconds, then check if new ServiceL2Status objects are created WITHOUT errors
sleep 30 && oc get servicel2status -A -o wide


# Step 4: Check speaker logs for errors vs. successful announcements
oc logs -n metallb-system -l component=speaker -c speaker --tail=50
