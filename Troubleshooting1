echo "=== ARP checks from master02 (same VLAN) ==="
oc debug node/ocp-ai-master02.calix.local -- chroot /host bash -c '
for vip in 10.172.194.160 10.172.194.161 10.172.194.163; do
  echo -n "$vip -> "
  arping -c 2 -w 3 -I bnd0.1794 $vip 2>&1 | tail -3
done
