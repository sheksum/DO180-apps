# From master01 (which has bnd0.1794 with IP 10.172.194.150), arping the VIP
ssh -i .ssh/ocp-ai core@ocp-ai-master01.calix.local "arping -c 3 -I bnd0.1794 10.172.194.160"


# Check ALL errors across ALL speakers right now
for pod in $(oc get pods -n metallb-system -l component=speaker -o name); do
  echo "=== $pod ==="
  oc logs -n metallb-system $pod -c speaker --tail=100 | grep -i "error" | tail -5
done

# Check current ServiceL2Status - see if they exist and are clean
oc get servicel2status -n metallb-system -o custom-columns='NAME:.metadata.name,NODE:.status.node,SVC:.status.serviceName,NS:.status.serviceNamespace'


# And check the speaker logs for any ARP socket opening or ARP activity on VLAN interfaces
SPEAKER01=$(oc get pods -n metallb-system -o wide | grep master01 | awk '{print $1}')
oc logs -n metallb-system $SPEAKER01 -c speaker --tail=200 | grep -iE "arp|socket|bind|open|listen|bnd0" | head -20
