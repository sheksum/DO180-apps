# Step 1: Verify ip_forward using nsenter (host network namespace)
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- cat /proc/sys/net/ipv4/ip_forward

# Step 2: Also check on the other masters
oc debug node/ocp-ai-master02.calix.local -- nsenter -t 1 -m -u -i -n -p -- cat /proc/sys/net/ipv4/ip_forward
oc debug node/ocp-ai-master03.calix.local -- nsenter -t 1 -m -u -i -n -p -- cat /proc/sys/net/ipv4/ip_forward

# Step 3: Enable ip_forward on master01
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- sysctl -w net.ipv4.ip_forward=1

