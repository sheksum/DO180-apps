# Check current ServiceL2Status assignments
oc get servicel2status -n metallb-system -o custom-columns='NAME:.metadata.name,NODE:.status.node,SVC:.status.serviceName,NS:.status.serviceNamespace'

# Check all LoadBalancer services and their IPs
oc get svc -A --field-selector spec.type=LoadBalancer -o custom-columns='NS:.metadata.namespace,NAME:.metadata.name,IP:.status.loadBalancer.ingress[0].ip,PORTS:.spec.ports[*].port'


# Check speaker logs on master02 (where VIPs appeared) for any VLAN activity
SPEAKER02=$(oc get pods -n metallb-system -o wide | grep master02 | awk '{print $1}')
oc logs -n metallb-system $SPEAKER02 -c speaker --tail=200 | grep -iE "10\.172\.194|10\.172\.202|10\.172\.198|announce|arp|gratuitous|SetBalancer|assign" | head -40


# Also recheck /32 addresses - maybe they're still propagating
for node in master01 master02 master03; do
  echo "=== $node ==="
  ssh -i .ssh/ocp-ai core@ocp-ai-${node}.calix.local "ip addr show | grep '/32'"
done
