# 1. Events on one of the LB services — does MetalLB report any issues?
oc describe svc minio-lb -n pai-dev | tail -20

# 2. Broader speaker logs — look for errors, interface issues, or election problems
oc logs -n metallb-system -l component=speaker --all-containers --tail=200 | grep -iE "error|fail|interface|announce|assign|reject|bnd0|bond0"

# 3. Check the controller logs for assignment issues
oc logs -n metallb-system deployment/controller --all-containers --tail=200 | grep -iE "error|fail|assign|10.172.194|pai-services"

# 4. Does the speaker even see the L2Advertisement / interfaces?
oc logs -n metallb-system -l component=speaker --all-containers --tail=500 | grep -iE "l2advertisement|interface|vlan1794"


# 5. Does the service have externalTrafficPolicy: Local?
oc get svc minio-lb -n pai-dev -o jsonpath='{.spec.externalTrafficPolicy}'
echo

# 6. Are there endpoints backing the service? (if externalTrafficPolicy=Local, 
#    MetalLB only assigns VIP to a node running a backend pod)
oc get endpoints minio-lb -n pai-dev
oc get pods -n pai-dev -l app=minio -o wide
