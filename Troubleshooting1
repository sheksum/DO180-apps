oc get pods -n metallb-system -l component=speaker -o wide

# Get the master01 speaker pod name directly
SPEAKER01=$(oc get pods -n metallb-system -l component=speaker -o jsonpath='{range .items[*]}{.metadata.name}{" "}{.spec.nodeName}{"\n"}{end}' | grep master01 | awk '{print $1}')
echo "Speaker01 pod: $SPEAKER01"

# Get the FULL unfiltered log from master01 speaker - look for the service reconciler handling LoadBalancer services
oc logs -n metallb-system $SPEAKER01 -c speaker --tail=500 | grep -iE "SetBalancer|minio-lb|milvus-lb|pg-lb|pai-dev|pai-prod|pai-test|loadbalancer|10\.172\.194|10\.172\.202|10\.172\.198|handler returned|not on this node|not owner|skipping" | head -40
