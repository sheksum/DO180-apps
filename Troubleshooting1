oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- bash -c '
  echo "=== Current nat OUTPUT chain ==="
  iptables -t nat -S OUTPUT

  echo "=== Applying fixes ==="
  # Fix 1: Add DNAT in OUTPUT chain for localhost access
  iptables -t nat -I OUTPUT -d 10.172.194.160/32 -p tcp --dport 9000 -j DNAT --to-destination 172.30.168.89:9000

  # Fix 2: Add VIP as local address so kernel accepts incoming packets
  #         on bnd0.1794 instead of dropping them before netfilter
  ip addr add 10.172.194.160/32 dev bnd0.1794

  echo "=== Verify VIP assigned ==="
  ip addr show bnd0.1794 | grep 10.172.194.160

  echo "=== Test localhost ==="
  nc -zv -w 3 10.172.194.160 9000 2>&1 || true
'

