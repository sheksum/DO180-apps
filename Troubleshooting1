SPEAKER03=$(oc get pods -n metallb-system -o wide | grep master03 | awk '{print $1}')
oc logs -n metallb-system $SPEAKER03 -c speaker --tail=1000 | grep -v "speaker-monitor-service" | grep -v "announced interface to exclude" | head -80


oc get csv -n metallb-system -o jsonpath='{.items[0].metadata.name}'

oc exec -n metallb-system $SPEAKER03 -c speaker -- /bin/speaker --help 2>&1 | head -30


oc get daemonset speaker -n metallb-system -o jsonpath='{.spec.template.spec.containers[?(@.name=="speaker")].image}'
