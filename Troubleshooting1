oc debug node/ocp-ai-master01.calix.local -- chroot /host bash -c '
# Disable rp_filter on br-ex
echo 0 > /proc/sys/net/ipv4/conf/br-ex/rp_filter
echo "br-ex rp_filter now: $(cat /proc/sys/net/ipv4/conf/br-ex/rp_filter)"

# Also set default to 0 so new interfaces inherit it
echo 0 > /proc/sys/net/ipv4/conf/default/rp_filter
echo "default rp_filter now: $(cat /proc/sys/net/ipv4/conf/default/rp_filter)"

# Zero the DNAT counter for a clean test
echo "Before test:"
iptables -t nat -L OVN-KUBE-EXTERNALIP -v -n | grep 9000 | head -1
iptables -L FORWARD -v -n | grep -E "FWD-VLAN|172.30"

echo ""
echo "Now test from master02: curl -m5 http://10.172.194.160:9000"
echo "Sleeping 15 seconds for you to test..."
sleep 15

echo ""
echo "After test:"
iptables -t nat -L OVN-KUBE-EXTERNALIP -v -n | grep 9000 | head -1
iptables -L FORWARD -v -n | grep -E "FWD-VLAN|172.30"
iptables -t nat -L POSTROUTING -v -n | grep -E "MASQ|masq" | head -3
nstat -z | grep IPReversePathFilter
'
