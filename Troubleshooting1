# 1. The crash logs from the new pod — what made it crash 3 times?
oc logs -n metallb-system speaker-gn45f -c speaker --previous

# 2. What's in the exclude list? This could be the whole problem.
oc get configmap metallb-excludel2 -n metallb-system -o yaml

# 3. Force the log level by editing the DaemonSet directly
oc set env daemonset/speaker -n metallb-system -c speaker LOG_LEVEL=debug 2>/dev/null; \
oc patch daemonset speaker -n metallb-system --type json -p '[{"op":"replace","path":"/spec/template/spec/containers/0/args","value":["--port=29150","--log-level=debug","--host=localhost","--frrk8s-namespace=openshift-frr-k8s"]}]'

# 4. Wait for rollout
oc rollout status daemonset/speaker -n metallb-system --timeout=60s

# 5. Then immediately grab logs from any speaker
oc logs -n metallb-system -l component=speaker -c speaker --tail=500

oc patch application metallb -n openshift-gitops --type merge -p '{"spec":{"syncPolicy":{"automated":{"selfHeal":true,"prune":true}}}}'
