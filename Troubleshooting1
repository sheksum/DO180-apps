echo "=== CNPG cluster details ==="
oc get cluster pai-apps-db -n pai-prod -o jsonpath='{.status.phase}{"\n"}'

echo ""
echo "=== Events ==="
oc get events -n pai-prod --sort-by=.lastTimestamp --field-selector reason!=Pulling,reason!=Pulled | tail -20

echo ""
echo "=== PVC status ==="
oc get pvc -n pai-prod -l cnpg.io/cluster=pai-apps-db

echo ""
echo "=== CNPG operator logs ==="
oc logs -n cnpg-system deployment/cnpg-controller-manager --tail=30 2>/dev/null | grep -i "pai-prod\|pai-apps-db\|error"
