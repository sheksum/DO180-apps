# 1. nftables netdev/ingress hooks (fire BEFORE iptables)
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  nft list ruleset | grep -B3 -A10 "hook ingress"

# 2. tc ingress filters on the VLAN interface
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  tc filter show dev bnd0.1794 ingress

# 3. tc ingress filters on the parent bond
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  tc filter show dev bnd0 ingress

# 4. eBPF programs attached to any interfaces
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  bpftool net show

# 5. Also verify: with the original MAC, does the packet actually reach ip_rcv?
#    Check the broader drop stats
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  nstat -z | grep -i "drop\|filter\|InDiscard"
