# Enable debug logging on the speaker DaemonSet
oc set env daemonset/speaker -n metallb-system METALLB_LOG_LEVEL=debug

# Check current speaker args
oc get daemonset speaker -n metallb-system -o jsonpath='{.spec.template.spec.containers[0].args}' | python3 -m json.tool


# Also verify speakers are running and on which nodes
oc get pods -n metallb-system -o wide | grep speaker


# And critically - check if speakers are running with hostNetwork (they need it to see host interfaces)
oc get daemonset speaker -n metallb-system -o jsonpath='{.spec.template.spec.hostNetwork}'
