# Check current setting
oc get network.operator cluster -o jsonpath='{.spec.defaultNetwork.ovnKubernetesConfig.gatewayConfig.ipForwarding}'
echo

# Apply the fix — tells OVN-Kubernetes to stop resetting ip_forward
oc patch network.operator cluster -p '{"spec":{"defaultNetwork":{"ovnKubernetesConfig":{"gatewayConfig":{"ipForwarding": "Global"}}}}}' --type=merge


# Watch the network operator status
oc get co network -w

# Once stable, verify ip_forward is now 1
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- cat /proc/sys/net/ipv4/ip_forward

# Then test
oc debug node/ocp-ai-master02.calix.local -- chroot /host nc -zv -w 3 10.172.194.160 9000
