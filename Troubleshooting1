for node in ocp-ai-master01.calix.local ocp-ai-master02.calix.local ocp-ai-master03.calix.local; do
  echo "=== $node ==="
  oc debug node/$node -- chroot /host bash -c '
    if ! iptables -t nat -C POSTROUTING -m conntrack --ctstate DNAT -o br-ex -j MASQUERADE 2>/dev/null; then
      iptables -t nat -I POSTROUTING -m conntrack --ctstate DNAT -o br-ex -j MASQUERADE
      echo "MASQUERADE rule added"
    else
      echo "MASQUERADE rule already exists"
    fi
  '
done


