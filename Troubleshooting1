# 1. What service actually uses this VIP?
oc get svc -A -o wide | grep 10.172.194.160

# 2. Does the ClusterIP (172.30.168.89) work from master01?
oc debug node/ocp-ai-master01.calix.local -- chroot /host nc -zv -w 3 172.30.168.89 9000

# 3. Is there a DNAT rule in nat OUTPUT for localhost traffic?
#    (PREROUTING only handles incoming traffic, OUTPUT handles locally-originated)
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  iptables -t nat -S | grep 10.172.194.160

# 4. Check ALL servicel2statuses — what VIPs are actually being announced?
oc get servicel2status -n metallb-system -o custom-columns='NAME:.metadata.name,NODE:.status.node,SVC:.spec.serviceRef.name,NS:.spec.serviceRef.namespace'

# 5. What does OVN think about this VIP? Check the load balancer
oc debug node/ocp-ai-master01.calix.local -- nsenter -t 1 -m -u -i -n -p -- \
  ovn-nbctl --no-leader-only lb-list | grep 10.172.194.160
