echo "=== L2Advertisements ==="
oc get l2advertisements -A -o yaml | grep -A 20 "spec:"

echo ""
echo "=== IPAddressPools ==="
oc get ipaddresspools -A -o yaml | grep -A 10 "spec:"

echo ""
echo "=== ARP for all VIPs from this host ==="
for vip in 10.172.194.160 10.172.194.161 10.172.194.163 10.172.202.160 10.172.202.161 10.172.198.160 10.172.198.161; do
  echo -n "$vip -> "
  arping -c 1 -w 2 $vip 2>&1 | grep -E "reply|timeout" | head -1
done


for pod in $(oc get pods -n metallb-system -l component=speaker -o name); do
  node=$(oc get $pod -n metallb-system -o jsonpath='{.spec.nodeName}')
  echo "=== $node ==="
  oc logs $pod -n metallb-system --tail=200 2>/dev/null | grep -i "announc" | tail -10
done
