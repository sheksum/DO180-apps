# Get all EXPIRED cert DNs
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=certificateRepository,ou=ca,o=ipaca" \
  -s one "(certStatus=EXPIRED)" dn \
  2>/dev/null | grep "^dn:" > /tmp/expired_certs.txt

# Get all REVOKED_EXPIRED cert DNs
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=certificateRepository,ou=ca,o=ipaca" \
  -s one "(certStatus=REVOKED_EXPIRED)" dn \
  2>/dev/null | grep "^dn:" >> /tmp/expired_certs.txt

# Confirm the count before we delete anything
wc -l /tmp/expired_certs.txt
cat /tmp/expired_certs.txt | head -10
