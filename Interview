# Delete all expired and revoked_expired certs
while read dn; do
  dn_value="${dn#dn: }"
  ldapdelete -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
    "$dn_value" 2>&1
done < /tmp/expired_certs.txt | tee /tmp/expired_certs_delete.log

# Confirm when done
echo "Deleted: $(grep -c "^$" /tmp/expired_certs_delete.log) entries"
wc -l /tmp/expired_certs_delete.log

