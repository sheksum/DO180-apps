### 3.4 Load and Push on Registry Server

```bash
cat > ~/load-push-gitlab.sh << 'EOF'
#!/bin/bash
INTERNAL_REGISTRY="img-registry.ttmtech.local:5000"

cd /root
tar -xzf gitlab-images.tar.gz
cd /root/var/lib/longhorn/gitlab-images

for tar in *.tar; do
  podman load -i $tar
done

images=(
  "docker.io/bitnamilegacy/postgres-exporter:0.15.0-debian-11-r7"
  "docker.io/bitnamilegacy/postgresql:16.6.0"
  "docker.io/bitnamilegacy/redis:7.2.4-debian-12-r9"
  "docker.io/bitnamilegacy/redis-exporter:1.58.0-debian-12-r4"
  "registry.gitlab.com/gitlab-org/build/cng/certificates:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitaly:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-base:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-container-registry:v4.38.0-gitlab"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-exporter:16.6.0"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-kas:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-shell:v14.47.0"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-sidekiq-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-toolbox-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-webservice-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-workhorse-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/kubectl:v18.10.3"
)

for image in "${images[@]}"; do
  name=$(echo $image | awk -F'/' '{print $NF}')
  podman tag $image $INTERNAL_REGISTRY/gitlab/$name
  podman push $INTERNAL_REGISTRY/gitlab/$name --tls-verify=false
done
EOF

chmod +x ~/load-push-gitlab.sh
~/load-push-gitlab.sh
