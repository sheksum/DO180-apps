## Step 4 — Kubernetes Secrets

Create all required secrets before deploying GitLab:

```bash
kubectl create namespace gitlab

# Wildcard TLS certificate
kubectl create secret tls wildcard-apps-ttmtech-tls \
  -n gitlab \
  --cert=/root/rke2-artifacts/cert.pem \
  --key=/root/rke2-artifacts/key.pem

# Object storage connection
cat > /tmp/rails.yaml << 'EOF'
provider: AWS
region: us-east-1
aws_access_key_id: <gitlab-service-account-access-key>
aws_secret_access_key: <gitlab-service-account-secret-key>
endpoint: "https://minio-api.apps.ttmtech.com"
path_style: true
EOF

kubectl create secret generic gitlab-rails-storage \
  -n gitlab \
  --from-file=connection=/tmp/rails.yaml
rm /tmp/rails.yaml

# Registry storage
cat > /tmp/registry.yaml << 'EOF'
s3:
  bucket: gitlab-registry-storage
  accesskey: <gitlab-service-account-access-key>
  secretkey: <gitlab-service-account-secret-key>
  regionendpoint: https://minio-api.apps.ttmtech.com
  region: us-east-1
  v4auth: true
  pathstyle: true
EOF

kubectl create secret generic gitlab-registry-storage \
  -n gitlab \
  --from-file=config=/tmp/registry.yaml
rm /tmp/registry.yaml

# Initial root password
kubectl create secret generic gitlab-gitlab-initial-root-password \
  -n gitlab \
  --from-literal=password="$(openssl rand -base64 12)"

# SMTP password (empty - relay requires no auth)
kubectl create secret generic gitlab-smtp-password \
  -n gitlab \
  --from-literal=password=""

# LDAP service account password
kubectl create secret generic gitlab-ldap-secret \
  -n gitlab \
  --from-literal=password="<ldap-service-account-password>"
```

