## Step 3 — Image Mirroring (Air-Gapped)

The cluster has no internet access. All images must be pulled on an internet-connected machine and pushed to the internal registry.

### 3.1 Configure RKE2 Registry on All Nodes

File: `/etc/rancher/rke2/registries.yaml`

```yaml
mirrors:
  registry.k8s.io:
    endpoint:
      - "https://img-registry.ttmtech.local"
  docker.io:
    endpoint:
      - "https://img-registry.ttmtech.local"
  ghcr.io:
    endpoint:
      - "https://img-registry.ttmtech.local"
  quay.io:
    endpoint:
      - "https://img-registry.ttmtech.local"
  registry.gitlab.com:
    endpoint:
      - "http://img-registry.ttmtech.local:5000"
  img-registry.ttmtech.local:5000:
    endpoint:
      - "http://img-registry.ttmtech.local:5000"
configs:
  "img-registry.ttmtech.local":
    tls:
      insecure_skip_verify: true
```

Copy to all nodes and restart rke2:

```bash
for node in aamhilcp01 aamhilcp03 aamhilwk01 aamhilwk02 aamhilwk03 aamhilwk04; do
  scp /etc/rancher/rke2/registries.yaml asvc.rhautomation@${node}.ttmtech.local:/tmp/
  ssh asvc.rhautomation@${node}.ttmtech.local "sudo cp /tmp/registries.yaml /etc/rancher/rke2/registries.yaml"
done

# Restart control planes
ssh asvc.rhautomation@aamhilcp01.ttmtech.local "sudo systemctl restart rke2-server"
ssh asvc.rhautomation@aamhilcp03.ttmtech.local "sudo systemctl restart rke2-server"

# Restart workers
for node in aamhilwk01 aamhilwk02 aamhilwk03 aamhilwk04; do
  ssh asvc.rhautomation@${node}.ttmtech.local "sudo systemctl restart rke2-agent"
  sleep 30
done
```

### 3.2 Pull and Save Images (Internet-Connected Machine)

```bash
cat > ~/pull-save-gitlab.sh << 'EOF'
#!/bin/bash
SAVE_DIR="/var/lib/longhorn/gitlab-images"
mkdir -p $SAVE_DIR

images=(
  "docker.io/bitnamilegacy/postgres-exporter:0.15.0-debian-11-r7"
  "docker.io/bitnamilegacy/postgresql:16.6.0"
  "docker.io/bitnamilegacy/redis:7.2.4-debian-12-r9"
  "docker.io/bitnamilegacy/redis-exporter:1.58.0-debian-12-r4"
  "registry.gitlab.com/gitlab-org/build/cng/certificates:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitaly:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-base:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-container-registry:v4.38.0-gitlab"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-exporter:16.6.0"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-kas:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-shell:v14.47.0"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-sidekiq-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-toolbox-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-webservice-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/gitlab-workhorse-ce:v18.10.3"
  "registry.gitlab.com/gitlab-org/build/cng/kubectl:v18.10.3"
)

for image in "${images[@]}"; do
  name=$(echo $image | awk -F'/' '{print $NF}' | tr ':' '-')
  echo "Pulling $image..."
  podman pull $image
  podman save -o $SAVE_DIR/$name.tar $image
done

tar -czf /var/lib/longhorn/gitlab-images.tar.gz $SAVE_DIR/
echo "Done: $(du -sh /var/lib/longhorn/gitlab-images.tar.gz)"
EOF

chmod +x ~/pull-save-gitlab.sh
