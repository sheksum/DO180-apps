# Confirm 57 is truly gone from all RUV lists (should see no "replica 57")
sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
  repl-agmt list --suffix="dc=ipa,dc=calix,dc=local" 2>&1 | grep -E "replica 5[0-9]"

# Check the replication tasks log for any timing details
sudo ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "cn=tasks,cn=config" "(cn=clean*)" cn nsTaskCreated nsTaskStatus nsTaskExitCode 2>&1 | grep -iE "^cn:|^nsTask"

# Current replication state summary
sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
  replication monitor 2>&1 | head -80
