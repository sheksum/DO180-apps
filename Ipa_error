# LDAP reachability
time ldapsearch -x -H ldap://cpeg-ipareplica.ipa.calix.local -s base -b "" "(objectclass=*)" 2>&1 | tail -3

# Kerberos reachability
nc -zv cpeg-ipareplica.ipa.calix.local 88
nc -zv cpeg-ipareplica.ipa.calix.local 389

# Check latest SSSD log after the restart
sudo tail -100 /var/log/sssd/sssd_ipa.calix.local.log | grep -v "^ "


# Kick sssd_be to retry online check immediately (uses dbus)
sudo sss_cache -E
sudo systemctl restart sssd
sleep 10
sudo sssctl domain-status ipa.calix.local


sudo cat /etc/sssd/sssd.conf
