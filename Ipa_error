sudo sed -i 's|^ipa_server = _srv_, cpeg-ipareplica.ipa.calix.local|ipa_server = cpeg-ipareplica.ipa.calix.local|' /etc/sssd/sssd.conf
sudo grep ipa_server /etc/sssd/sssd.conf
sudo sss_cache -E
sudo systemctl restart sssd

for i in $(seq 1 30); do
  echo "$(date +%H:%M:%S) $(sudo sssctl domain-status ipa.calix.local | grep 'Online status')"
  sleep 30
