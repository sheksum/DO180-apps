# Local-only replication status on cpeg
sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
  replication status --suffix="dc=ipa,dc=calix,dc=local"

# Or check the agreement-by-agreement status
sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
  repl-agmt status --suffix="dc=ipa,dc=calix,dc=local" \
  cpeg-ipareplica.ipa.calix.local-to-nan-ipareplica01.ipa.calix.local

sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
  repl-agmt status --suffix="dc=ipa,dc=calix,dc=local" \
  cpeg-ipareplica.ipa.calix.local-to-ric-ipareplica01.ipa.calix.local

sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
