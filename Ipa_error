ping -c 2 sjc-ipareplica01.ipa.calix.local
ssh sjc-ipareplica01.ipa.calix.local "ipactl status | head -5"


# Pull the slow 1.29s op above — find its SRCH line
grep -B1 "conn=4436386 op=49 " /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/access | head -5

# Get 10 recent unindexed SRCH patterns
grep "notes=U" /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/access | tail -20 | awk '{for(i=1;i<=NF;i++) if($i~/conn=|op=/) printf "%s ",$i; print ""}' | while read conn op rest; do
  grep "$conn $op SRCH " /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/access | tail -1
done


