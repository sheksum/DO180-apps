# Watch the error log in real time
sudo tail -20 /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/errors

# Count pln-ipamaster errors in the last minute
sudo grep -c "meTopln-ipamaster" /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/errors
sudo grep "meTopln-ipamaster" /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/errors | tail -5


# This needs to run on pln-ipamaster, not cpeg
ssh root@pln-ipamaster
# Then:
sudo ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "cn=config" "(objectClass=nsds5ReplicationAgreement)" \
  dn nsds5replicaHost nsds5ReplicaEnabled 2>&1 | grep -E "^dn:|nsds5replicaHost|nsds5ReplicaEnabled"
