# 1. What DNS servers is this client using?
cat /etc/resolv.conf
resolvectl status 2>/dev/null || systemd-resolve --status 2>/dev/null

# 2. Try the SRV query directly
dig +short SRV _ldap._tcp.ipa.calix.local
dig SRV _ldap._tcp.ipa.calix.local

# 3. Try against cpeg (which runs IPA DNS)
dig @172.23.49.10 SRV _ldap._tcp.ipa.calix.local

# 4. What other IPA SRV records should exist?
dig @172.23.49.10 SRV _kerberos._tcp.ipa.calix.local
dig @172.23.49.10 SRV _kerberos._udp.ipa.calix.local
dig @172.23.49.10 SRV _kpasswd._tcp.ipa.calix.local


# What's in the ipa.calix.local zone?
ipa dnsrecord-find ipa.calix.local | grep -iE "srv|_ldap|_kerberos"

# Or specifically
ipa dnsrecord-show ipa.calix.local "_ldap._tcp"
ipa dnsrecord-show ipa.calix.local "_kerberos._tcp"
