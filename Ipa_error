# Check effective config
systemd-analyze cat-config systemd/journald.conf | grep -iE "ForwardToConsole|MaxLevelConsole|TTYPath"

# Or check if the journal IS forwarding
journalctl --header 2>/dev/null | head -5

# Check what's in journal from SSSD in the last minute
journalctl -u sssd --since "1 minute ago" --no-pager | tail -20

# Also check rsyslog config - it can forward too
grep -rE "cron\.|auth\.|\*\.\*" /etc/rsyslog.conf /etc/rsyslog.d/ 2>/dev/null | grep -i console




grep -E "^(ForwardToConsole|MaxLevelConsole|TTYPath)" /etc/systemd/journald.conf
sudo journalctl -u sssd --since "5 minutes ago" --no-pager | tail -20
