# On cpeg - check history for ipa-replica-manage or dsconf commands
sudo grep -E "ipa-replica-manage|dsconf.*repl" /root/.bash_history /home/*/.bash_history 2>/dev/null | head -50

# Check systemd journal for ipa commands that ran in the last 30 days
sudo journalctl --since "30 days ago" | grep -iE "ipa-replica-manage|replica.*remove|cleanallruv" | head -30

