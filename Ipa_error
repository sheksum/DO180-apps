# On sjc
sudo ldapsearch -Y EXTERNAL -H ldapi://%2Fvar%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "cn=replica,cn=dc\3Dipa\2Cdc\3Dcalix\2Cdc\3Dlocal,cn=mapping tree,cn=config" \
  2>&1 | grep -v "^$" | head -30

# Check if sjc has replication agreements back to cpeg
sudo ldapsearch -Y EXTERNAL -H ldapi://%2Fvar%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "cn=config" "(objectClass=nsds5ReplicationAgreement)" \
  nsds5replicaHost nsds5replicaLastUpdateStatus nsds5ReplicaEnabled \
  2>&1 | grep -v "^$" | head -40

# Check replication plugin status
sudo ldapsearch -Y EXTERNAL -H ldapi://%2Fvar%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "cn=Multimaster Replication Plugin,cn=plugins,cn=config" nsslapd-pluginEnabled \
  2>&1 | grep -i "pluginEnabled"

# Check sjc's RUV for the suffix
sudo ldapsearch -Y EXTERNAL -H ldapi://%2Fvar%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "dc=ipa,dc=calix,dc=local" "(objectclass=nsTombstone)" \
  nsds50ruv nsds50ruvReplicaLastModified 2>&1 | head -20
