# List all replication agreements from cpeg
sudo dsconf -D "cn=Directory Manager" ldap://cpeg-ipareplica.ipa.calix.local \
  repl-agmt list --suffix="dc=ipa,dc=calix,dc=local" 2>&1 | grep -E "^dn:|nsds5replicaHost|nsds5ReplicaEnabled"

# See what ipa-replica-manage says  
ipa-replica-manage list

# Also check the access log with the right timestamp format
sudo grep "17/Apr/2026:15:09:3" /var/log/dirsrv/slapd-IPA-CALIX-LOCAL/access | head -20
