## Onboarding New Systems

### Step 1 — Install NRPE on target (run on target system)

```bash
dnf install -y epel-release
dnf install -y nrpe nagios-plugins-ping nagios-plugins-load nagios-plugins-disk \
  nagios-plugins-procs nagios-plugins-users nagios-plugins-ssh nagios-plugins-tcp

# Update allowed_hosts
sed -i 's/^allowed_hosts=.*/allowed_hosts=127.0.0.1,10.45.10.171,10.45.10.172,10.45.10.173,10.45.10.174,10.42.0.0\/16/' /etc/nagios/nrpe.cfg

# Update check thresholds
sed -i 's|command\[check_load\]=.*|command[check_load]=/usr/lib64/nagios/plugins/check_load -r -w 2.0,1.5,1.0 -c 4.0,3.0,2.0|' /etc/nagios/nrpe.cfg
sed -i 's|command\[check_disk\]=.*|command[check_disk]=/usr/lib64/nagios/plugins/check_disk -w 20% -c 10% -p /|' /etc/nagios/nrpe.cfg

systemctl enable nrpe
systemctl start nrpe
```

### Step 2 — Verify connectivity from Nagios pod

```bash
NAGIOS_POD=$(kubectl get pod -n monitoring -l app=nagios -o jsonpath='{.items[0].metadata.name}')
kubectl exec -n monitoring $NAGIOS_POD -- /usr/lib/nagios/plugins/check_nrpe -H <TARGET_IP>
# Expected: NRPE v4.1.2
```

### Step 3 — Add host/service definitions (inside Nagios pod)

```bash
kubectl exec -it -n monitoring $NAGIOS_POD -- bash
vi /opt/nagios/etc/conf.d/<hostname>.cfg
```

Template:

```
define host {
    host_name               <hostname>
    alias                   <Friendly Name>
    address                 <IP>
    max_check_attempts      3
    check_period            24x7
    notification_interval   30
    notification_period     24x7
    check_command           check-host-alive
    contact_groups          admins
}

define service {
    host_name               <hostname>
    service_description     PING
    check_command           check_ping!100.0,20%!500.0,60%
    max_check_attempts      3
    check_period            24x7
    notification_interval   30
    notification_period     24x7
    contact_groups          admins
}

define service {
    host_name               <hostname>
    service_description     CPU Load
    check_command           check_nrpe!check_load
    max_check_attempts      3
    check_period            24x7
    notification_interval   30
    notification_period     24x7
    contact_groups          admins
}

define service {
    host_name               <hostname>
    service_description     Disk Usage
    check_command           check_nrpe!check_disk
    max_check_attempts      3
    check_period            24x7
    notification_interval   30
    notification_period     24x7
    contact_groups          admins
}
```

### Step 4 — Validate and reload

```bash
nagios -v /opt/nagios/etc/nagios.cfg
kill -HUP $(pgrep nagios)
```

