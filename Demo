metadata:
  name: cnpg-lb
  namespace: pai-prod
  annotations:
    metallb.universe.tf/address-pool: pai-services-prod
    metallb.universe.tf/loadBalancerIPs: "10.172.202.160"
spec:
  type: LoadBalancer
  ports:
    - name: postgresql
      port: 5432
      targetPort: 5432
      protocol: TCP
  selector:
    app: cnpg
