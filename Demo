cat > ~/ocp-ai-config/ldap-group-sync/sync-config.yaml << 'EOF'
apiVersion: v1
kind: ConfigMap
metadata:
  name: ldap-group-sync-config
  namespace: ldap-group-sync
data:
  sync.yaml: |
    kind: LDAPSyncConfig
    apiVersion: v1
    url: ldaps://cpeg-ipareplica.ipa.calix.local
    ca: /etc/ldap-sync/ca.crt
    bindDN: uid=ldapbind,cn=users,cn=accounts,dc=ipa,dc=calix,dc=local
    bindPassword:
      file: /etc/ldap-sync/bindPassword
    insecure: false
    rfc2307:
      groupsQuery:
        baseDN: cn=groups,cn=accounts,dc=ipa,dc=calix,dc=local
        scope: sub
        derefAliases: never
        filter: (|(cn=engops)(cn=mlops))
      groupUIDAttribute: dn
      groupNameAttributes:
      - cn
      groupMembershipAttributes:
      - member
      usersQuery:
        baseDN: cn=users,cn=accounts,dc=ipa,dc=calix,dc=local
        scope: sub
        derefAliases: never
      userUIDAttribute: dn
      userNameAttributes:
      - uid
EOF

cat > ~/ocp-ai-config/ldap-group-sync/cronjob.yaml << 'EOF'
apiVersion: batch/v1
kind: CronJob
metadata:
  name: ldap-group-sync
  namespace: ldap-group-sync
spec:
  schedule: "*/30 * * * *"
  concurrencyPolicy: Forbid
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 3
  jobTemplate:
    spec:
      template:
        spec:
          serviceAccountName: ldap-group-sync
          restartPolicy: Never
          containers:
          - name: ldap-group-sync
            image: registry.redhat.io/openshift4/ose-cli:latest
            command:
            - /bin/bash
            - -c
            - oc adm groups sync --sync-config=/etc/ldap-sync/sync.yaml --confirm
            volumeMounts:
            - name: sync-config
              mountPath: /etc/ldap-sync/sync.yaml
              subPath: sync.yaml
            - name: ldap-ca
              mountPath: /etc/ldap-sync/ca.crt
              subPath: ca.crt
            - name: bind-password
              mountPath: /etc/ldap-sync/bindPassword
              subPath: bindPassword
          volumes:
          - name: sync-config
            configMap:
              name: ldap-group-sync-config
          - name: ldap-ca
            configMap:
              name: ldap-ca
          - name: bind-password
            secret:
              secretName: ldap-bind-password
EOF



# Create the namespace first so we can create secrets in it
oc create namespace ldap-group-sync

# Create the CA ConfigMap and bind password Secret manually
oc create configmap ldap-ca \
  --from-file=ca.crt=/tmp/ldap-ca.crt \
  -n ldap-group-sync

oc create secret generic ldap-bind-password \
  --from-file=bindPassword=/tmp/ldap-bind-password \
  -n ldap-group-sync




