apiVersion: apps/v1
kind: Deployment
metadata:
  annotations:
    meta.helm.sh/release-name: general-agent-router-module
    meta.helm.sh/release-namespace: pai-dev
  labels:
    app: general-agent-router-module
    app.kubernetes.io/instance: general-agent-router-module
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/name: general-agent-router-module
    app.kubernetes.io/version: 1.0.0
    helm.sh/chart: general-agent-router-module-1.0.0
  name: general-agent-router-module
  namespace: pai-dev
spec:
  progressDeadlineSeconds: 600
  replicas: 1
  revisionHistoryLimit: 10
  selector:
    matchLabels:
      app.kubernetes.io/instance: general-agent-router-module
      app.kubernetes.io/name: general-agent-router-module
  strategy:
    rollingUpdate:
      maxSurge: 25%
      maxUnavailable: 25%
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: general-agent-router-module
        app.kubernetes.io/instance: general-agent-router-module
        app.kubernetes.io/name: general-agent-router-module
    spec:
      automountServiceAccountToken: false
      containers:
      - args:
        - --model-repository=/models
        - --load-model=distilbert
        - --model-control-mode=explicit
        - --allow-gpu-metrics=false
        - --pinned-memory-pool-byte-size=0
        - --cuda-memory-pool-byte-size=0:0
        - --backend-config=onnxruntime,enable_gpu=false
        - --backend-config=pytorch,enable_gpu=false
        - --backend-config=tensorflow,allow_gpu=false
        - --backend-config=tensorflow,enable_gpu=false
        - --disable-auto-complete-config
        command:
        - /opt/tritonserver/bin/tritonserver
        env:
        - name: CUDA_VISIBLE_DEVICES
          value: "-1"
        - name: NVIDIA_VISIBLE_DEVICES
          value: none
        - name: NVIDIA_DRIVER_CAPABILITIES
        - name: TRITON_SERVER_CPU_ONLY
          value: "1"
        image: nvcr.io/nvidia/tritonserver:23.10-py3
        imagePullPolicy: IfNotPresent
        livenessProbe:
          failureThreshold: 3
          httpGet:
            path: /v2/health/live
            port: http
            scheme: HTTP
          initialDelaySeconds: 30
          periodSeconds: 20
          successThreshold: 1
          timeoutSeconds: 3
        name: general-agent-router-module
        ports:
        - containerPort: 8000
          name: http
          protocol: TCP
        - containerPort: 8001
          name: grpc
          protocol: TCP
        - containerPort: 8002
          name: metrics
          protocol: TCP
        readinessProbe:
          failureThreshold: 3
          httpGet:
            path: /v2/health/ready
            port: http
            scheme: HTTP
          initialDelaySeconds: 30
          periodSeconds: 20
          successThreshold: 1
          timeoutSeconds: 3
        resources:
          limits:
            memory: 10Gi
          requests:
            cpu: "1"
            memory: 2Gi
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
        volumeMounts:
        - mountPath: /models
          name: model
      dnsPolicy: ClusterFirst
      imagePullSecrets:
      - name: reg-secret
      initContainers:
      - name: model-loader
        image: minio/mc:latest
        imagePullPolicy: IfNotPresent
        command:
        - sh
        - -c
        - |
          mc alias set minio http://minio.pai-dev.svc:9000 $MINIO_ROOT_USER $MINIO_ROOT_PASSWORD
          mc cp --recursive minio/distilbert/ /models/distilbert/
          echo "--- Model files downloaded ---"
          ls -R /models/
        env:
        - name: MINIO_ROOT_USER
          valueFrom:
            secretKeyRef:
              name: minio-credentials
              key: MINIO_ROOT_USER
        - name: MINIO_ROOT_PASSWORD
          valueFrom:
            secretKeyRef:
              name: minio-credentials
              key: MINIO_ROOT_PASSWORD
        resources: {}
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
        volumeMounts:
        - mountPath: /models
          name: model
      restartPolicy: Always
      schedulerName: default-scheduler
      securityContext: {}
      serviceAccount: general-agent-router-module
      serviceAccountName: general-agent-router-module
      terminationGracePeriodSeconds: 30
      volumes:
      - name: model
        emptyDir: {}
