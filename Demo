## Template D: TLS Certificate

Use this to request a TLS certificate from the platform's Vault PKI. The certificate is automatically issued and renewed by cert-manager.

```yaml
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: <YOUR-APP-NAME>-tls
  namespace: <YOUR-NAMESPACE>
  # pai-dev, pai-test, or pai-prod
spec:
  secretName: <YOUR-APP-NAME>-tls-secret
  issuerRef:
    name: vault-issuer           # do not change
    kind: ClusterIssuer          # do not change
  dnsNames:
    - <YOUR-HOSTNAME>
    # Format: <app-name>.<env>.ocp-ai.calix.local
    # pai-dev  = <app-name>.dev.ocp-ai.calix.local
    # pai-test = <app-name>.test.ocp-ai.calix.local
    # pai-prod = <app-name>.prod.ocp-ai.calix.local
  duration: 8760h                # 1 year
  renewBefore: 720h              # renews 30 days before expiry
```

### Verify

```bash
oc get certificate <YOUR-APP-NAME>-tls -n <YOUR-NAMESPACE>
# Should show READY: True
oc get secret <YOUR-APP-NAME>-tls-secret -n <YOUR-NAMESPACE>
```

### Mount in Your Pod

```yaml
volumes:
  - name: tls-certs
    secret:
      secretName: <YOUR-APP-NAME>-tls-secret
volumeMounts:
  - name: tls-certs
    mountPath: /etc/tls
    readOnly: true
```

### EXAMPLE ONLY -- TLS certificate for Triton inference API in pai-dev

```yaml
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: triton-tls
  namespace: pai-dev
spec:
  secretName: triton-tls-secret
  issuerRef:
    name: vault-issuer
    kind: ClusterIssuer
  dnsNames:
    - inference.dev.ocp-ai.calix.local
  duration: 8760h
  renewBefore: 720h
```

Mounting the cert in your Deployment:

```yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: triton-server
  namespace: pai-dev
spec:
  replicas: 1
  selector:
    matchLabels:
      app: triton-server
  template:
    metadata:
      labels:
        app: triton-server
    spec:
      containers:
        - name: triton-server
          image: registry.calix.local/ai/triton:latest
          ports:
            - containerPort: 8000
          volumeMounts:
            - name: tls-certs
              mountPath: /etc/tls
              readOnly: true
          resources:
            requests:
              cpu: "2"
              memory: "4Gi"
            limits:
              cpu: "8"
              memory: "16Gi"
      volumes:
        - name: tls-certs
          secret:
            secretName: triton-tls-secret
```

