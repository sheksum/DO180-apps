# Remove yourself from engops, add to mlops
ipa group-remove-member engops --users=hsuma
ipa group-add-member mlops --users=hsuma

# Login with your IPA account using a separate kubeconfig
KUBECONFIG=/tmp/test-kubeconfig oc login -u hsuma https://api.ocp-ai.calix.local:6443 --insecure-skip-tls-verify

# Test prod — should FAIL (view only)
KUBECONFIG=/tmp/test-kubeconfig oc create configmap test-rbac --from-literal=key=value -n pai-prod

# Test test — should WORK (edit)
KUBECONFIG=/tmp/test-kubeconfig oc create configmap test-rbac --from-literal=key=value -n pai-test

# Test dev — should WORK (admin)
KUBECONFIG=/tmp/test-kubeconfig oc create configmap test-rbac --from-literal=key=value -n pai-dev

# Test exec in prod — should FAIL
KUBECONFIG=/tmp/test-kubeconfig oc exec -n pai-prod deploy/milvus -- ls
