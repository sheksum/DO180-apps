# ConfigMap
oc get configmap milvus-config -n pai-dev -o yaml

# ClusterIP Service
oc get svc milvus -n pai-dev -o yaml

# LoadBalancer Service
oc get svc milvus-lb -n pai-dev -o yaml

# Check test and prod for differences
oc get deployment milvus -n pai-test -o yaml | grep -E "image:|memory:|cpu:|ROOT_PATH|BUCKET_NAME|MINIO_ADDRESS"
oc get deployment milvus -n pai-prod -o yaml | grep -E "image:|memory:|cpu:|ROOT_PATH|BUCKET_NAME|MINIO_ADDRESS"

# Prod services
oc get svc -n pai-prod | grep milvus
oc get svc -n pai-test | grep milvus
