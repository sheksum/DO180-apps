# Get the caBundle
CABUNDLE=$(oc get secretstore vault-store -n pai-dev -o jsonpath='{.spec.provider.vault.caBundle}')

# Create the eso directory
mkdir -p ~/ocp-ai-config/eso

# Generate all manifests
cat > ~/ocp-ai-config/eso/secretstores.yaml << ENDOFFILE
---
apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: vault-store
  namespace: pai-dev
spec:
  provider:
    vault:
      server: https://vault.calix.local:8200
      path: kv
      version: v2
      caBundle: ${CABUNDLE}
      auth:
        kubernetes:
          mountPath: kubernetes-ocp-ai
          role: eso-pai-dev
          serviceAccountRef:
            name: external-secrets
            namespace: pai-dev
---
apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: vault-store
  namespace: pai-test
spec:
  provider:
    vault:
      server: https://vault.calix.local:8200
      path: kv
      version: v2
      caBundle: ${CABUNDLE}
      auth:
        kubernetes:
          mountPath: kubernetes-ocp-ai
          role: eso-pai-test
          serviceAccountRef:
            name: external-secrets
---
apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: vault-store
  namespace: pai-prod
spec:
  provider:
    vault:
      server: https://vault.calix.local:8200
      path: kv
      version: v2
      caBundle: ${CABUNDLE}
      auth:
        kubernetes:
          mountPath: kubernetes-ocp-ai
          role: eso-pai-prod
          serviceAccountRef:
            name: external-secrets
---
apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: vault-store
  namespace: trident
spec:
  provider:
    vault:
      server: https://vault.calix.local:8200
      path: kv
      version: v2
      caBundle: ${CABUNDLE}
      auth:
        kubernetes:
          mountPath: kubernetes-ocp-ai
          role: eso-trident
          serviceAccountRef:
            name: external-secrets
ENDOFFILE

cat > ~/ocp-ai-config/eso/externalsecrets-trident.yaml << 'EOF'
---
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: backend-app-secret
  namespace: trident
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: vault-store
    kind: SecretStore
  target:
    name: backend-app-secret
    creationPolicy: Owner
    deletionPolicy: Retain
  data:
    - secretKey: username
      remoteRef:
        key: trident/app
        property: username
    - secretKey: password
      remoteRef:
        key: trident/app
        property: password
---
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: backend-infra-secret
  namespace: trident
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: vault-store
    kind: SecretStore
  target:
    name: backend-infra-secret
    creationPolicy: Owner
    deletionPolicy: Retain
  data:
    - secretKey: username
      remoteRef:
        key: trident/infra
        property: username
    - secretKey: password
      remoteRef:
        key: trident/infra
        property: password
EOF




cat > ~/ocp-ai-config/apps/eso.yaml << 'EOF'
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: eso
  namespace: openshift-gitops
spec:
  project: default
  source:
    repoURL: git@bitbucket.org:calixprod/ocp-ai-platform.git
    targetRevision: main
    path: eso
  destination:
    server: https://kubernetes.default.svc
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=false
EOF


head -20 ~/ocp-ai-config/eso/secretstores.yaml
cat ~/ocp-ai-config/eso/externalsecrets-trident.yaml
cat ~/ocp-ai-config/apps/eso.yaml
