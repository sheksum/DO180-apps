cat > /tmp/ldap-group-sync.yaml << 'EOF'
kind: LDAPSyncConfig
apiVersion: v1
url: ldaps://cpeg-ipareplica.ipa.calix.local
ca: /tmp/ldap-ca.crt
bindDN: uid=ldapbind,cn=users,cn=accounts,dc=ipa,dc=calix,dc=local
bindPassword:
  file: /tmp/ldap-bind-password
insecure: false
rfc2307:
  groupsQuery:
    baseDN: cn=groups,cn=accounts,dc=ipa,dc=calix,dc=local
    scope: sub
    derefAliases: never
    filter: (|(cn=engops)(cn=mlops))
  groupUIDAttribute: dn
  groupNameAttributes:
  - cn
  groupMembershipAttributes:
  - member
  usersQuery:
    baseDN: cn=users,cn=accounts,dc=ipa,dc=calix,dc=local
    scope: sub
    derefAliases: never
  userUIDAttribute: dn
  userNameAttributes:
  - uid
EOF
