CABUNDLE=""

cat > ~/ocp-ai-config/ldap-group-sync/eso.yaml << EOF
---
apiVersion: external-secrets.io/v1
kind: SecretStore
metadata:
  name: vault-store
  namespace: ldap-group-sync
spec:
  provider:
    vault:
      server: https://vault.calix.local:8200
      path: kv
      version: v2
      caBundle: ${CABUNDLE}
      auth:
        kubernetes:
          mountPath: kubernetes-ocp-ai
          role: eso-ldap-group-sync
          serviceAccountRef:
            name: external-secrets
---
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: ldap-bind-password
  namespace: ldap-group-sync
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: vault-store
    kind: SecretStore
  target:
    name: ldap-bind-password
    creationPolicy: Owner
    deletionPolicy: Retain
  data:
  - secretKey: bindPassword
    remoteRef:
      key: ldap-group-sync/bind-password
      property: bindPassword
EOF


oc delete secret ldap-bind-password -n ldap-group-sync


cd ~/ocp-ai-config
git add ldap-group-sync/ apps/ldap-group-sync.yaml
git commit -m "Add LDAP group sync CronJob with RBAC and Vault-managed bind password"
git push


oc create job --from=cronjob/ldap-group-sync ldap-group-sync-test -n ldap-group-sync
oc logs -n ldap-group-sync -l job-name=ldap-group-sync-test -f
