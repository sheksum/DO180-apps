# What's running in pai-dev for postgres
oc get pods -n pai-dev | grep -i postgres

# Services
oc get svc -n pai-dev | grep -i postgres

# Check if there's a LoadBalancer service
oc get svc -n pai-dev -o wide | grep -i postgres

# Check endpoints
oc get endpoints -n pai-dev | grep -i postgres

# Any new HTTPRoutes
oc get httproutes -n pai-dev

# Check if Gene created a new Gateway
oc get gateway -A

# NetworkPolicies in pai-dev
oc get networkpolicy -n pai-dev
