# Check if the speaker has the right permissions to send ARPs
oc get pod $(oc get pods -n metallb-system -l component=speaker -o name | head -1 | cut -d/ -f2) -n metallb-system -o yaml | grep -A3 "capabilities\|NET_RAW\|securityContext" | head -20

# Check the speaker's assigned services
oc logs -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker 2>&1 | head -50

