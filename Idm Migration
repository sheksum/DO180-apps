# Check speaker logs for errors
oc logs -n metallb-system -l component=speaker --all-containers | grep -i "error\|fail\|cannot\|unable" | tail -20

# Check if the speaker can see the interface
oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -- ip link show | grep bnd0.1794

# Which node is the leader for this service?
oc logs -n metallb-system -l component=speaker --all-containers | grep -i "leader\|winning\|minio" | tail -10

# Restart the speakers to force re-announcement
oc delete pods -n metallb-system -l component=speaker


