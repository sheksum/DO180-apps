# Stop DS
systemctl stop dirsrv@IPA-CALIX-LOCAL

# Reset DM password to match cpeg
dsctl IPA-CALIX-LOCAL root-dn-pwd-change

# Start DS
systemctl start dirsrv@IPA-CALIX-LOCAL

# Verify it works
ldapsearch -H ldap://pln-ipamaster.ipa.calix.local:389 \
  -x -D "cn=Directory Manager" -W \
  -b "" -s base


