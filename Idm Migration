# 1. Remove stale domain segment
ipa topologysegment-del domain \
  "pln-petipareplica.ipa.calix.local-to-nan-ipareplica01.ipa.calix.local"

# 2. Remove stale CA segment
ipa topologysegment-del ca \
  "cpeg-ipareplica.ipa.calix.local-to-pln-petipareplica.ipa.calix.local"

# 3. Remove stale replication agreement
ipa-replica-manage del pln-petipareplica.ipa.calix.local --force

# 4. Remove stale server entry
ipa server-del pln-petipareplica.ipa.calix.local --force

# 5. Remove stale host entry
ipa host-del pln-petipareplica.ipa.calix.local


# Verify hostname is set correctly
hostname -f
# Should return: pln-ipamaster.ipa.calix.local

# Verify DNS resolves both ways
dig pln-ipamaster.ipa.calix.local
dig -x <ip-of-pln-ipamaster>

# Verify NTP is actually syncing
chronyc tracking | grep -E "(Reference|System time|Leap)"
