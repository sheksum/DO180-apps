# Delete ALL ServiceL2Status objects
oc delete servicel2statuses.metallb.io -n metallb-system --all

# Delete the controller too — it manages the status objects
oc delete pod -n metallb-system -l component=controller

# Delete the speakers
oc delete pods -n metallb-system -l component=speaker

# Wait
sleep 45

# Check everything is up
oc get pods -n metallb-system

# Check fresh status objects
oc get servicel2statuses.metallb.io -A

# Test
nc -zv -w 3 10.172.194.160 9000

oc get subscription -n metallb-system -o yaml | grep -A2 installPlanApproval
