# Check what ports are open in the speaker container
oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker -- ss -tlnp 2>/dev/null || oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker -- netstat -tlnp 2>/dev/null

# Check the speaker process args again
oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker -- cat /proc/1/cmdline | tr '\0' ' '

# Check if there's a NetworkPolicy on the controller blocking speaker-to-speaker
oc get networkpolicy controller -n metallb-system -o yaml
