# Confirm pln-petipareplica is truly gone from IPA's perspective
ipa server-show pln-petipareplica.ipa.calix.local

# Check if it still has a host entry
ipa host-show pln-petipareplica.ipa.calix.local

# See if the stale CA segment is still there
ipa topologysegment-show ca \
  "cpeg-ipareplica.ipa.calix.local-to-pln-petipareplica.ipa.calix.local"

# Same for the domain segment
ipa topologysegment-show domain \
  "pln-petipareplica.ipa.calix.local-to-nan-ipareplica01.ipa.calix.local"

# Check if it still has a replication agreement lurking
ipa-replica-manage list
