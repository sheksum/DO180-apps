kinit admin
ipa service-add ipa-dnskeysyncd/pln-ipamaster.ipa.calix.local
ipa-getkeytab -s pln-ipamaster.ipa.calix.local \
  -p ipa-dnskeysyncd/pln-ipamaster.ipa.calix.local \
  -k /etc/ipa/dnssec/ipa-dnskeysyncd.keytab
chown root:ods /etc/ipa/dnssec/ipa-dnskeysyncd.keytab
chmod 440 /etc/ipa/dnssec/ipa-dnskeysyncd.keytab
systemctl restart ipa-dnskeysyncd
