# Force speaker restart
oc delete pods -n metallb-system -l component=speaker
sleep 20
oc logs -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker --tail=100


oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker -- ps aux 2>/dev/null || oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker -- ls /proc/1/cmdline
