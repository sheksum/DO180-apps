# Full recent speaker logs - no filtering
oc logs -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker --tail=50

# Check the frr-k8s container too
oc logs -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c frr-k8s --tail=20 2>/dev/null

# List all containers in the speaker pod
oc get pod $(oc get pods -n metallb-system -l component=speaker -o name | head -1 | cut -d/ -f2) -n metallb-system -o jsonpath='{.spec.containers[*].name}'
