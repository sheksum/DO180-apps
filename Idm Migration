# Check MetalLB operator version
oc get csv -n metallb-system | grep metallb

# Check if the MetalLB CR config is correct
oc get metallb -n metallb-system -o yaml

# Force a full restart of everything MetalLB
oc delete pods -n metallb-system --all
sleep 30
oc get pods -n metallb-system

# Then immediately check fresh speaker logs
oc logs -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker 2>&1
