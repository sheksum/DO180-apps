# Check what secret the Gateway listener is using
oc get gateway pai-gateway -n openshift-ingress -o yaml | grep -A10 "https-legacy-dev"

# Check the cert details
oc get secret agentmesh-dev-ai-tls -n openshift-ingress -o jsonpath='{.data.tls\.crt}' | base64 -d | openssl x509 -text -noout | grep -E "Issuer|Subject|Not After|DNS"
