# Are there any NetworkPolicies in metallb-system?
oc get networkpolicy -n metallb-system

# Check if speakers can reach each other on port 7946
oc exec -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker -- cat /etc/metallb/memberlist-secret 2>/dev/null

# Check full speaker logs for memberlist errors
oc logs -n metallb-system $(oc get pods -n metallb-system -l component=speaker -o name | head -1) -c speaker --tail=30 | grep -i "member\|join\|peer\|connect"
