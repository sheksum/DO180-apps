# 1. Remove the stale domain topology segment
ipa topologysegment-del domain \
  "pln-petipareplica.ipa.calix.local-to-nan-ipareplica01.ipa.calix.local"

# 2. Remove the stale CA topology segment
ipa topologysegment-del ca \
  "cpeg-ipareplica.ipa.calix.local-to-pln-petipareplica.ipa.calix.local"

# 3. Remove the replication agreement
ipa-replica-manage del pln-petipareplica.ipa.calix.local --force

# 4. Remove the server entry
ipa server-del pln-petipareplica.ipa.calix.local --force

# 5. Remove the host entry last
ipa host-del pln-petipareplica.ipa.calix.local


ipa topologysegment-find domain
ipa topologysegment-find ca
ipa-replica-manage list
ipa server-role-find
