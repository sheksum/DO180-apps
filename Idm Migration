# On pln-ipamaster
ipa-server-install --uninstall

# On cpeg-ipareplica
ipa-replica-manage del pln-ipamaster.ipa.calix.local --force
ipa topologysegment-find domain
ipa-replica-manage list


# On pln-ipamaster
ipa-replica-install \
  --setup-ca \
  --setup-dns \
  --no-forwarders \
  --no-ntp \
  --server cpeg-ipareplica.ipa.calix.local \
  --domain ipa.calix.local \
  --realm IPA.CALIX.LOCAL \
  --principal admin \
  --admin-password '<password>' \
  --skip-conncheck \
  --timeout 300
