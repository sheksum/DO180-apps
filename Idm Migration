# Revert the --host arg back to localhost
oc patch daemonset speaker -n metallb-system --type='json' -p='[{"op":"replace","path":"/spec/template/spec/containers/0/args/2","value":"--host=localhost"}]'

# Delete speakers to pick up the revert
oc delete pods -n metallb-system -l component=speaker

# Scale operator back up
oc scale deployment metallb-operator-controller-manager -n metallb-system --replicas=1

# Wait
sleep 30

oc get pods -n metallb-system
