cd ~/rhocp_ansible_install_cluster_ahv

# Back up the original template
cp templates/install-config.yaml.j2 templates/install-config.yaml.j2.bak


additionalTrustBundlePolicy: Proxyonly
apiVersion: v1
baseDomain: {{ rhocp_base_domain }}

to

apiVersion: v1
baseDomain: {{ rhocp_base_domain }}
additionalTrustBundle: |
{{ rhocp_additional_trust_bundle | indent(2, True) }}
additionalTrustBundlePolicy: Always


# Find the CSC CAs in the system trust store
for f in /etc/pki/ca-trust/source/anchors/*.pem /etc/pki/ca-trust/source/anchors/*.crt 2>/dev/null; do
  [ -f "$f" ] || continue
  subj=$(openssl x509 -in "$f" -noout -subject 2>/dev/null)
  if echo "$subj" | grep -qi 'corporation service'; then
    echo "=== $f ==="
    echo "$subj"
  fi
done

awk '/BEGIN CERTIFICATE/{n++} {print > "/tmp/ca-"n".pem"}' \
  /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem

for f in /tmp/ca-*.pem; do
  subj=$(openssl x509 -in "$f" -noout -subject 2>/dev/null)
  if echo "$subj" | grep -qi 'corporation service'; then
    echo "=== $f ==="
    echo "$subj"
  fi
done


cd ~/rhocp_ansible_install_cluster_ahv

cat > /tmp/render-test.yml <<'EOF'
- hosts: localhost
  connection: local
  gather_facts: false
  vars:
    rhocp_base_domain: cscglobal.com
    rhocp_cluster_name: ocpdrbubble
    rhocp_architecture: amd64
    rhocp_control_plane_vcpu: 8
    rhocp_control_plane_memory: 32768
    rhocp_cluster_network: 10.128.0.0/14
    rhocp_machine_network: 10.163.1.0/24
    rhocp_service_network: 172.30.0.0/16
    rhocp_api_vip: 10.163.1.10
    rhocp_ingress_vip: 10.163.1.11
    rhocp_prism_central_fqdn: us2-prismcentral01.cscinfo.com
    rhocp_pc_username: dummy
    rhocp_pc_password: dummy
    rhocp_pe_endpoint: dummy
    rhocp_ntnx_pe_uuid: dummy
    rhocp_ntnx_pe_subnet_uuid: dummy
    rhocp_pull_secret: '{}'
    rhocp_core_ssh_key: 'ssh-rsa AAAA dummy'
    rhocp_additional_trust_bundle: "{{ lookup('file', '/tmp/csc-ca-bundle.pem') }}"
  tasks:
    - template:
        src: templates/install-config.yaml.j2
        dest: /tmp/install-config.yaml
EOF

# Build the bundle file with both CAs (adjust paths to what you found in step 2)
cat /tmp/ca-<issuing>.pem /tmp/ca-<root>.pem > /tmp/csc-ca-bundle.pem

ansible-playbook /tmp/render-test.yml

# Check it's valid YAML
python3 -c "import yaml; yaml.safe_load(open('/tmp/install-config.yaml'))" && echo "VALID YAML"

# Eyeball the trust bundle section (should show proper 2-space indent)
sed -n '/additionalTrustBundle:/,/additionalTrustBundlePolicy:/p' /tmp/install-config.yaml





