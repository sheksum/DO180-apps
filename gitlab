cd ~/hil-infrastructure
git pull

python3 << 'PYEOF'
import yaml

with open('apps/monitoring/nagios-deployment.yaml') as f:
    doc = yaml.safe_load(f)

# Remove git-sync container
containers = doc['spec']['template']['spec']['containers']
doc['spec']['template']['spec']['containers'] = [c for c in containers if c['name'] != 'git-sync']

# Remove git-data volume
volumes = doc['spec']['template']['spec']['volumes']
doc['spec']['template']['spec']['volumes'] = [v for v in volumes if v['name'] != 'git-data']

with open('apps/monitoring/nagios-deployment.yaml', 'w') as f:
    yaml.dump(doc, f, default_flow_style=False)
print("git-sync removed")
PYEOF

git add apps/monitoring/nagios-deployment.yaml
git commit -m "fix: remove git-sync sidecar to restore Nagios service"
git push
flux reconcile kustomization apps --with-source
kubectl rollout status deployment/nagios -n monitoring
