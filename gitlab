python3 << 'PYEOF'
import yaml

with open('apps/monitoring/nagios-deployment.yaml') as f:
    doc = yaml.safe_load(f)

# Add shareProcessNamespace
doc['spec']['template']['spec']['shareProcessNamespace'] = True

with open('apps/monitoring/nagios-deployment.yaml', 'w') as f:
    yaml.dump(doc, f, default_flow_style=False)
print("Done")
PYEOF

python3 -c "
import yaml
with open('apps/monitoring/nagios-deployment.yaml') as f:
    doc = yaml.safe_load(f)
print('shareProcessNamespace:', doc['spec']['template']['spec'].get('shareProcessNamespace'))
"

kubectl create configmap nagios-sync-script \
  --from-literal=sync.sh='#!/bin/sh
cp -r /git/current/apps/monitoring/conf.d/. /opt/nagios/etc/conf.d/
kill -HUP $(pgrep -f "nagios /opt/nagios/etc/nagios.cfg" | head -1)
echo "Nagios config synced and reloaded"
' \
  -n monitoring --dry-run=client -o yaml | kubectl apply -f -

git add apps/monitoring/nagios-deployment.yaml
git commit -m "fix: add shareProcessNamespace for git-sync to signal nagios"
git push
flux reconcile kustomization apps --with-source
kubectl rollout status deployment/nagios -n monitoring


