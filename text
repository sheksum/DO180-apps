vault write auth/ldap/config \
  url="ldaps://cpeg-ipareplica.ipa.calix.local" \
  binddn="uid=<BIND-USER>,cn=users,cn=accounts,dc=ipa,dc=calix,dc=local" \
  bindpass="<BIND-PASSWORD>" \
  userdn="cn=users,cn=accounts,dc=ipa,dc=calix,dc=local" \
  userattr="uid" \
  groupdn="cn=groups,cn=accounts,dc=ipa,dc=calix,dc=local" \
  groupattr="cn" \
  groupfilter="(|(memberUid={{.Username}})(member={{.UserDN}})(uniqueMember={{.UserDN}}))" \
  insecure_tls=false \
  starttls=false \
  certificate=@/path/to/ipa-ca.crt


  curl -k https://cpeg-ipareplica.ipa.calix.local/ipa/config/ca.crt -o /tmp/ipa-ca.crt


  ldapsearch -x -H ldaps://cpeg-ipareplica.ipa.calix.local \
  -D "uid=<BIND-USER>,cn=users,cn=accounts,dc=ipa,dc=calix,dc=local" \
  -W \
  -b "cn=users,cn=accounts,dc=ipa,dc=calix,dc=local" \
  "(uid=hsuma)" uid cn


  vault write auth/ldap/groups/<IPA-GROUP> policies=<VAULT-POLICY>
