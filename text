# Full access to all OCP-AI secrets
path "secret/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

path "secret/metadata/*" {
  capabilities = ["list", "read", "delete"]
}

# PKI - issue and manage certs
path "pki_int/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

# Auth and system visibility
path "sys/mounts" {
  capabilities = ["read", "list"]
}

path "sys/auth" {
  capabilities = ["read", "list"]
}


  # Read/write secrets for each environment
path "secret/data/pai-dev/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

path "secret/data/pai-test/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

path "secret/data/pai-prod/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

# Metadata access (needed for UI listing)
path "secret/metadata/pai-dev/*" {
  capabilities = ["list", "read", "delete"]
}

path "secret/metadata/pai-test/*" {
  capabilities = ["list", "read", "delete"]
}

path "secret/metadata/pai-prod/*" {
  capabilities = ["list", "read", "delete"]
}

# List top-level paths (needed for UI navigation)
path "secret/metadata/*" {
  capabilities = ["list"]
}


