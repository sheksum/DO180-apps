    return "n/a"

def get_role(labels):
    if "node-role.kubernetes.io/master" in labels or "node-role.kubernetes.io/control-plane" in labels:
        return "control"
    if "node-role.kubernetes.io/infra" in labels:
        return "infra"
    return "compute"

def get_cluster_name(override):
    if override:
        return override
    try:
        infra = oc("get", "infrastructure", "cluster")
        return infra.get("status", {}).get("infrastructureName", "unknown")
    except SystemExit:
        return "unknown"

def node_name_to_machineset(node_name):
    parts = node_name.split("-")
    if len(parts) >= 5:
        return "-".join(parts[:4])
    if len(parts) == 4:
        return "-".join(parts[:3])
    return ""

