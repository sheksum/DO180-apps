def oc(*args):
    cmd = ["oc"] + list(args) + ["-o", "json"]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print("[ERROR] oc " + " ".join(args) + " failed:\n" + result.stderr, file=sys.stderr)
        sys.exit(1)
    return json.loads(result.stdout)

def millicore_to_cores(val):
    if val.endswith("m"):
        return round(int(val[:-1]) / 1000, 1)
    return float(val)

def ki_to_gib(val):
    if val.endswith("Ki"):
        return round(int(val[:-2]) / (1024 ** 2), 1)
    if val.endswith("Mi"):
        return round(int(val[:-2]) / 1024, 1)
    if val.endswith("Gi"):
        return round(float(val[:-2]), 1)
    return round(int(val) / (1024 ** 3), 1)

def gi_str_to_int(val):
    if not val:
        return None
    val = str(val).strip()
    if val.endswith("Gi"):
        return int(float(val[:-2]))
    if val.endswith("Mi"):
        return int(float(val[:-2]) / 1024)
    if val.endswith("G"):
        return int(float(val[:-1]))
    try:
        return int(val)
    except ValueError:
        return None

