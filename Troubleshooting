# Get the password
PGPASS=$(oc get secret cnpg-test-app -n pai-test -o jsonpath='{.data.password}' | base64 -d)

# Connect with password in the URI
oc run pg-test --rm -it --image=postgres:17 --restart=Never -n pai-test -- \
  psql "host=cnpg-test-rw port=5432 dbname=testdb user=testuser password=$PGPASS sslmode=require"


