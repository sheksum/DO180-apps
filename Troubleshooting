# Check cluster status
oc get cluster cnpg-test -n pai-test

# Verify credentials got created
oc get secret cnpg-test-app -n pai-test -o jsonpath='{.data.username}' | base64 -d && echo
oc get secret cnpg-test-app -n pai-test -o jsonpath='{.data.password}' | base64 -d && echo

# Connect and write data
oc run pg-test --rm -it --image=postgres:17 --restart=Never -n pai-test -- \
  psql "host=cnpg-test-rw port=5432 dbname=testdb user=testuser sslmode=require"

CREATE TABLE test (id serial PRIMARY KEY, name text);
INSERT INTO test (name) VALUES ('hello from cnpg');
SELECT * FROM test;
\q

