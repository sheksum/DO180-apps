oc delete clusterlogforwarder collector -n openshift-logging

cat <<EOF | oc apply -f -
apiVersion: observability.openshift.io/v1
kind: ClusterLogForwarder
metadata:
  name: collector
  namespace: openshift-logging
spec:
  managementState: Managed
  serviceAccount:
    name: cluster-logging
  outputs:
  - name: graylog-syslog
    type: syslog
    syslog:
      rfc: RFC5424
      severity: informational
      facility: local6
      url: tcp://10.172.249.33:1517
    tls:
      insecureSkipVerify: true
  pipelines:
  - name: infra-to-graylog
    inputRefs:
    - infrastructure
    outputRefs:
    - graylog-syslog
EOF

sleep 20
oc get pods -n openshift-logging | grep collector
ssh -i ~/.ssh/ocp-ai core@ocp-ai-master02.calix.local "ss -tnp | grep 1517"
