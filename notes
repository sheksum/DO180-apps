# Delete the current one
oc delete clusterlogforwarder instance -n openshift-logging

# Create with the correct v6.x structure
cat <<EOF | oc apply -f -
apiVersion: observability.openshift.io/v1
kind: ClusterLogForwarder
metadata:
  name: collector
  namespace: openshift-logging
spec:
  managementState: Managed
  serviceAccount:
    name: cluster-logging
  outputs:
  - name: graylog-syslog
    type: syslog
    syslog:
      rfc: RFC5424
      severity: informational
      facility: local6
      url: tcp://10.172.249.33:1517
  pipelines:
  - name: infra-to-graylog
    inputRefs:
    - infrastructure
    outputRefs:
    - graylog-syslog
EOF

oc get clusterlogforwarder collector -n openshift-logging -o yaml | grep -A10 "conditions"

oc get pods -n openshift-logging


