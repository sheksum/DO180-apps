
oc create serviceaccount cluster-logging -n openshift-logging

hsuma@plnx-admin:~$ oc adm policy add-cluster-role-to-user cluster-role/collect-infrastructure-logs \
  system:serviceaccount:openshift-logging:cluster-logging
The ClusterRoleBinding "cluster-role/collect-infrastructure-logs" is invalid:
* metadata.name: Invalid value: "cluster-role/collect-infrastructure-logs": may not contain '/'
* roleRef.name: Invalid value: "cluster-role/collect-infrastructure-logs": may not contain '/'

cat <<EOF | oc apply -f -
apiVersion: observability.openshift.io/v1
kind: ClusterLogForwarder
metadata:
  name: instance
  namespace: openshift-logging
spec:
  serviceAccount:
    name: cluster-logging
  outputs:
  - name: graylog-syslog
    type: syslog
    syslog:
      rfc: RFC5424
      severity: informational
      facility: local6
    url: tcp://10.172.249.33:1517
  pipelines:
  - name: infra-to-graylog
    inputRefs:
    - infrastructure
    outputRefs:
    - graylog-syslog
EOF


oc get pods -n openshift-logging
oc get clusterlogforwarder -n openshift-logging
