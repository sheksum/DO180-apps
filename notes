oc logs -n openshift-logging $(oc get pods -n openshift-logging -o name | grep collector | head -1) --tail=30

oc exec -n openshift-logging $(oc get pods -n openshift-logging -o name | grep collector | head -1) -- cat /etc/vector/vector.toml 2>/dev/null | grep -A10 "syslog\|graylog\|1517"
