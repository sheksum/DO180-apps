# Delete the ClusterLogForwarder first
oc delete clusterlogforwarder collector -n openshift-logging

# Delete the subscription
oc delete subscription cluster-logging -n openshift-logging

# Delete the CSV
oc delete csv -n openshift-logging $(oc get csv -n openshift-logging -o name | grep cluster-logging)

# Verify operator is gone
oc get pods -n openshift-logging
