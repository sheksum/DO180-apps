oc annotate clusterlogforwarder collector -n openshift-logging observability.openshift.io/log-level=debug --overwrite

# Wait for pods to restart
sleep 30
oc get pods -n openshift-logging | grep collector

# Check debug logs for connection issues
oc logs -n openshift-logging $(oc get pods -n openshift-logging -o name | grep collector | head -1) --tail=30 | grep -v "fingerprint"
