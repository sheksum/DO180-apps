# Count total certificate requests
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ca,ou=requests,o=ipaca" \
  -s one "(objectclass=*)" dn 2>/dev/null | grep "^dn:" | wc -l


# Count by request state (complete, rejected, canceled, etc.)
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ca,ou=requests,o=ipaca" \
  -s one "(objectclass=*)" requestState 2>/dev/null \
  | grep "^requestState:" | sort | uniq -c | sort -rn

# Confirm which server is CA renewal master
ipa config-show | grep "CA renewal"

# Check pki-tomcat CA status and request count via REST
curl -sk https://cpeg-ipareplica.ipa.calix.local/ca/admin/ca/getStatus

# Check cert request range assigned to cpeg
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ranges,o=ipaca" "(objectclass=*)" 2>/dev/null | grep -E "^dn:|^cn:|^beginRange:|^endRange:"
