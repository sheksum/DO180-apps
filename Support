# Oldest request — what's the earliest one?
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ca,ou=requests,o=ipaca" \
  -s one "(requestState=complete)" requestCreateTime \
  2>/dev/null | grep "^requestCreateTime:" | sort | head -5

# Newest request
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ca,ou=requests,o=ipaca" \
  -s one "(requestState=complete)" requestCreateTime \
  2>/dev/null | grep "^requestCreateTime:" | sort | tail -5


# Count issued certs in the certificate repository
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=certificateRepository,ou=ca,o=ipaca" \
  -s one "(objectclass=*)" userCertificate \
  2>/dev/null | grep "^dn:" | wc -l

ipa --version
rpm -q ipa-server pki-ca
