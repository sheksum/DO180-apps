ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ca,ou=requests,o=ipaca" \
  -s one "(requestState=complete)" \
  2>/dev/null | head -60

# Get the first 3 request DNs
ldapsearch -Y EXTERNAL -H ldapi://%2Frun%2Fslapd-IPA-CALIX-LOCAL.socket \
  -b "ou=ca,ou=requests,o=ipaca" \
  -s one "(objectclass=*)" dn \
  2>/dev/null | grep "^dn:" | head -3

pki -d /etc/pki/pki-tomcat/alias \
    -C /etc/pki/pki-tomcat/password.conf \
    ca-cert-find --status VALID 2>/dev/null | head -40

# Check if pruning config exists in CS.cfg
grep -i "prune\|purge\|job" /etc/pki/pki-tomcat/ca/CS.cfg | grep -i "job\|prune" | head -20
